{
  "sources": [
    {
      "source_id": "src.th.dialogue.convenience_payment_card_cash",
      "title": "จ่ายเงินที่ร้านสะดวกซื้อ",
      "summary": "",
      "blocks": [
        {
          "block_id": "t1_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.convenience_payment_card_cash.t1_npc",
              "translation": "總共一百二十泰銖。付現金還是刷卡？"
            }
          ]
        },
        {
          "block_id": "t1_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.convenience_payment_card_cash.t1_learner",
              "translation": "卡片，謝謝。"
            }
          ]
        },
        {
          "block_id": "t2_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.convenience_payment_card_cash.t2_npc",
              "translation": "請在這裡感應卡片。"
            }
          ]
        },
        {
          "block_id": "t2_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.convenience_payment_card_cash.t2_learner",
              "translation": "好的。"
            }
          ]
        },
        {
          "block_id": "t3_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.convenience_payment_card_cash.t3_npc",
              "translation": "需要袋子嗎？"
            }
          ]
        },
        {
          "block_id": "t3_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.convenience_payment_card_cash.t3_learner",
              "translation": "不用袋子。"
            }
          ]
        },
        {
          "block_id": "t4_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.convenience_payment_card_cash.t4_npc",
              "translation": "好了，謝謝。"
            }
          ]
        },
        {
          "block_id": "t4_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.convenience_payment_card_cash.t4_learner",
              "translation": "謝謝。"
            }
          ]
        }
      ]
    },
    {
      "source_id": "src.th.dialogue.core_repair_repeat_slowly",
      "title": "ขอให้พูดอีกครั้ง",
      "summary": "",
      "blocks": [
        {
          "block_id": "t1_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.core_repair_repeat_slowly.t1_npc",
              "translation": "內用還是外帶？"
            }
          ]
        },
        {
          "block_id": "t1_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.core_repair_repeat_slowly.t1_learner",
              "translation": "不好意思，可以再說一次嗎？"
            }
          ]
        },
        {
          "block_id": "t2_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.core_repair_repeat_slowly.t2_npc",
              "translation": "內用還是外帶？"
            }
          ]
        },
        {
          "block_id": "t2_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.core_repair_repeat_slowly.t2_learner",
              "translation": "可以說慢一點嗎？"
            }
          ]
        },
        {
          "block_id": "t3_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.core_repair_repeat_slowly.t3_npc",
              "translation": "內用嗎？還是外帶？"
            }
          ]
        },
        {
          "block_id": "t3_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.core_repair_repeat_slowly.t3_learner",
              "translation": "外帶，謝謝。"
            }
          ]
        },
        {
          "block_id": "t4_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.core_repair_repeat_slowly.t4_npc",
              "translation": "好的，完成了。"
            }
          ]
        },
        {
          "block_id": "t4_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.core_repair_repeat_slowly.t4_learner",
              "translation": "謝謝。"
            }
          ]
        }
      ]
    },
    {
      "source_id": "src.th.dialogue.daily_meet_friend",
      "title": "เจอเพื่อน",
      "summary": "",
      "blocks": [
        {
          "block_id": "t1_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_meet_friend.t1_npc",
              "translation": "你來了啊？"
            }
          ]
        },
        {
          "block_id": "t1_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_meet_friend.t1_learner",
              "translation": "嗨，很高興見到你。"
            }
          ]
        },
        {
          "block_id": "t2_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_meet_friend.t2_npc",
              "translation": "我們要去看電影，對嗎？"
            }
          ]
        },
        {
          "block_id": "t2_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_meet_friend.t2_learner",
              "translation": "對，走吧。"
            }
          ]
        },
        {
          "block_id": "t3_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_meet_friend.t3_npc",
              "translation": "準備好了嗎？"
            }
          ]
        },
        {
          "block_id": "t3_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_meet_friend.t3_learner",
              "translation": "準備好了，走吧。"
            }
          ]
        },
        {
          "block_id": "t4_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_meet_friend.t4_npc",
              "translation": "先去買票吧。"
            }
          ]
        },
        {
          "block_id": "t4_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_meet_friend.t4_learner",
              "translation": "好，一起去買票吧。"
            }
          ]
        }
      ]
    },
    {
      "source_id": "src.th.dialogue.daily_schedule_time",
      "title": "นัดเวลาเจอกัน",
      "summary": "",
      "blocks": [
        {
          "block_id": "t1_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_schedule_time.t1_npc",
              "translation": "明天幾點見好呢？"
            }
          ]
        },
        {
          "block_id": "t1_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_schedule_time.t1_learner",
              "translation": "下午三點好嗎？"
            }
          ]
        },
        {
          "block_id": "t2_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_schedule_time.t2_npc",
              "translation": "下午三點可以，在車站見喔。"
            }
          ]
        },
        {
          "block_id": "t2_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_schedule_time.t2_learner",
              "translation": "可以，在車站見。"
            }
          ]
        },
        {
          "block_id": "t3_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_schedule_time.t3_npc",
              "translation": "好，明天下午三點見。"
            }
          ]
        },
        {
          "block_id": "t3_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_schedule_time.t3_learner",
              "translation": "好，到時見。"
            }
          ]
        },
        {
          "block_id": "t4_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_schedule_time.t4_npc",
              "translation": "好，明天見。"
            }
          ]
        },
        {
          "block_id": "t4_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_schedule_time.t4_learner",
              "translation": "到時見。"
            }
          ]
        }
      ]
    },
    {
      "source_id": "src.th.dialogue.daily_self_intro",
      "title": "แนะนำตัว",
      "summary": "",
      "blocks": [
        {
          "block_id": "t1_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_self_intro.t1_npc",
              "translation": "你好，我叫 Maya。你叫什麼名字？"
            }
          ]
        },
        {
          "block_id": "t1_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_self_intro.t1_learner",
              "translation": "你好，我叫 Alex。"
            }
          ]
        },
        {
          "block_id": "t2_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_self_intro.t2_npc",
              "translation": "你在學泰文，對嗎？"
            }
          ]
        },
        {
          "block_id": "t2_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_self_intro.t2_learner",
              "translation": "是的，我正在學泰文。"
            }
          ]
        },
        {
          "block_id": "t3_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_self_intro.t3_npc",
              "translation": "很好。很高興認識你。"
            }
          ]
        },
        {
          "block_id": "t3_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_self_intro.t3_learner",
              "translation": "我也很高興認識你。"
            }
          ]
        },
        {
          "block_id": "t4_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_self_intro.t4_npc",
              "translation": "很好，那我們開始吧。"
            }
          ]
        },
        {
          "block_id": "t4_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.daily_self_intro.t4_learner",
              "translation": "好的，謝謝。"
            }
          ]
        }
      ]
    },
    {
      "source_id": "src.th.dialogue.digital_battery_charging",
      "title": "ขอชาร์จมือถือ",
      "summary": "",
      "blocks": [
        {
          "block_id": "t1_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.digital_battery_charging.t1_npc",
              "translation": "有什麼需要幫忙嗎？"
            }
          ]
        },
        {
          "block_id": "t1_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.digital_battery_charging.t1_learner",
              "translation": "可以充手機嗎？"
            }
          ]
        },
        {
          "block_id": "t2_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.digital_battery_charging.t2_npc",
              "translation": "可以。"
            }
          ]
        },
        {
          "block_id": "t2_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.digital_battery_charging.t2_learner",
              "translation": "插座在哪裡？"
            }
          ]
        },
        {
          "block_id": "t3_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.digital_battery_charging.t3_npc",
              "translation": "在左手邊桌子下面。"
            }
          ]
        },
        {
          "block_id": "t3_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.digital_battery_charging.t3_learner",
              "translation": "左手邊桌子下面對嗎？"
            }
          ]
        },
        {
          "block_id": "t4_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.digital_battery_charging.t4_npc",
              "translation": "對，可以用那裡。"
            }
          ]
        },
        {
          "block_id": "t4_learner",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.digital_battery_charging.t4_learner",
              "translation": "謝謝。"
            }
          ]
        }
      ]
    },
    {
