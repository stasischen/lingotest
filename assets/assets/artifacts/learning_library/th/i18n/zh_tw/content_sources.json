    {
      "source_id": "src.th.dialogue.food_coffee_ordering",
      "title": "สั่งกาแฟ",
      "summary": "",
      "blocks": [
        {
          "block_id": "t1_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.food_coffee_ordering.t1_npc",
