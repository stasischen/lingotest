    {
      "source_id": "src.th.dialogue.food_restaurant_ordering",
      "title": "สั่งอาหารในร้านอาหาร",
      "summary": "",
      "blocks": [
        {
          "block_id": "t1_npc",
          "sentences": [
            {
              "sentence_id": "sent.src.th.dialogue.food_restaurant_ordering.t1_npc",
              "translation": "您好，幾位呢？"
