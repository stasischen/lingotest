          "translation": "不好意思，2號出口在哪裡？"
        },
        {
          "id": "sent.src.th.dialogue.travel_station_directions.t2_npc",
          "translation": "直走，然後右轉。"
        },
        {
          "id": "sent.src.th.dialogue.travel_station_directions.t2_learner",
          "translation": "直走，然後右轉對嗎？"
        },
        {
          "id": "sent.src.th.dialogue.travel_station_directions.t3_npc",
          "translation": "是的。2號出口在右邊。"
        },
        {
          "id": "sent.src.th.dialogue.travel_station_directions.t3_learner",
          "translation": "謝謝。"
        },
        {
          "id": "sent.src.th.dialogue.travel_station_directions.t4_npc",
          "translation": "不客氣。"
        },
        {
          "id": "sent.src.th.dialogue.travel_station_directions.t4_learner",
          "translation": "再次謝謝。"
        }
      ]
    },
    "src.th.dialogue.travel_taxi_destination": {
      "sentences": [
        {
          "id": "sent.src.th.dialogue.travel_taxi_destination.t1_npc",
          "translation": "要去哪裡？"
        },
        {
          "id": "sent.src.th.dialogue.travel_taxi_destination.t1_learner",
          "translation": "去這間飯店。"
        },
        {
          "id": "sent.src.th.dialogue.travel_taxi_destination.t2_npc",
          "translation": "這間飯店對吧？"
        },
        {
          "id": "sent.src.th.dialogue.travel_taxi_destination.t2_learner",
          "translation": "是的。"
        },
        {
          "id": "sent.src.th.dialogue.travel_taxi_destination.t3_npc",
          "translation": "大約十分鐘。"
        },
        {
          "id": "sent.src.th.dialogue.travel_taxi_destination.t3_learner",
          "translation": "好的，謝謝。"
        },
        {
          "id": "sent.src.th.dialogue.travel_taxi_destination.t4_npc",
          "translation": "到了。"
        },
        {
          "id": "sent.src.th.dialogue.travel_taxi_destination.t4_learner",
          "translation": "這裡可以。"
        }
      ]
    },
    "src.th.dialogue.travel_ticket_buying": {
      "sentences": [
        {
          "id": "sent.src.th.dialogue.travel_ticket_buying.t1_npc",
          "translation": "要去哪裡？"
        },
        {
          "id": "sent.src.th.dialogue.travel_ticket_buying.t1_learner",
          "translation": "請給我一張到中央車站的票。"
        },
        {
          "id": "sent.src.th.dialogue.travel_ticket_buying.t2_npc",
          "translation": "一張到中央車站，對嗎？"
        },
        {
          "id": "sent.src.th.dialogue.travel_ticket_buying.t2_learner",
          "translation": "是的。"
        },
        {
          "id": "sent.src.th.dialogue.travel_ticket_buying.t3_npc",
          "translation": "三十泰銖。二號月台。"
        },
        {
          "id": "sent.src.th.dialogue.travel_ticket_buying.t3_learner",
          "translation": "給你，謝謝。"
        },
        {
          "id": "sent.src.th.dialogue.travel_ticket_buying.t4_npc",
          "translation": "這是票。二號月台。"
        },
        {
          "id": "sent.src.th.dialogue.travel_ticket_buying.t4_learner",
          "translation": "二號月台。"
        }
      ]
    }
  }
}