{
  "sources": [
    {
      "source_id": "src.en.r250.en-a1-r250-article-ticket-001",
      "title": "Buying a Train Ticket",
      "summary": "",
      "blocks": [
        {
          "block_id": "en-a1-r250-article-ticket-001.u01",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-ticket-001.u01",
              "translation": "我在火車站。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-ticket-001.u02",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-ticket-001.u02",
              "translation": "我需要一張去巴黎的車票。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-ticket-001.u03",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-ticket-001.u03",
              "translation": "我走到售票窗口。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-ticket-001.u04",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-ticket-001.u04",
              "translation": "我要一張去巴黎的車票。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-ticket-001.u05",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-ticket-001.u05",
              "translation": "二十歐元。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-ticket-001.u06",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-ticket-001.u06",
              "translation": "我刷卡付款。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-ticket-001.u07",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-ticket-001.u07",
              "translation": "櫃檯人員把車票給我。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-ticket-001.u08",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-ticket-001.u08",
              "translation": "火車十點從三號月台出發。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-ticket-001.u09",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-ticket-001.u09",
              "translation": "我問幾點到。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-ticket-001.u10",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-ticket-001.u10",
              "translation": "下午兩點到。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-ticket-001.u11",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-ticket-001.u11",
              "translation": "我問車上有沒有吃的。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-ticket-001.u12",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-ticket-001.u12",
              "translation": "櫃檯人員說有一間小咖啡廳。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-ticket-001.u13",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-ticket-001.u13",
              "translation": "我已經準備好出發了。"
            }
          ]
        }
      ]
    },
    {
      "source_id": "src.en.r250.en-a1-r250-article-hotel-002",
      "title": "Checking In at a Hotel",
      "summary": "",
      "blocks": [
        {
          "block_id": "en-a1-r250-article-hotel-002.u01",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-hotel-002.u01",
              "translation": "我在飯店。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-hotel-002.u02",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-hotel-002.u02",
              "translation": "我有訂房。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-hotel-002.u03",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-hotel-002.u03",
              "translation": "我的名字是安娜．史密斯。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-hotel-002.u04",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-hotel-002.u04",
              "translation": "我把護照給櫃檯人員。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-hotel-002.u05",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-hotel-002.u05",
              "translation": "我的房間在二樓。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-hotel-002.u06",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-hotel-002.u06",
              "translation": "櫃檯人員給我房卡。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-hotel-002.u07",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-hotel-002.u07",
              "translation": "房間很漂亮。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-hotel-002.u08",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-hotel-002.u08",
              "translation": "我想要水。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-hotel-002.u09",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-hotel-002.u09",
              "translation": "櫃檯人員給我一瓶水。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-hotel-002.u10",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-hotel-002.u10",
              "translation": "我問早餐的事。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-hotel-002.u11",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-hotel-002.u11",
              "translation": "早餐七點在餐廳吃。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-article-hotel-002.u12",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-article-hotel-002.u12",
              "translation": "退房時間是十一點。"
            }
          ]
        }
      ]
    },
    {
      "source_id": "src.en.r250.en-a1-r250-dialogue-airport-001",
      "title": "Checking In at the Airport",
      "summary": "",
      "blocks": [
        {
          "block_id": "en-a1-r250-dialogue-airport-001.t01",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-dialogue-airport-001.t01",
              "translation": "A: 你好。我想辦理登機手續。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-dialogue-airport-001.t02",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-dialogue-airport-001.t02",
              "translation": "B: 可以看一下您的護照嗎？"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-dialogue-airport-001.t03",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-dialogue-airport-001.t03",
              "translation": "A: 給您。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-dialogue-airport-001.t04",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-dialogue-airport-001.t04",
              "translation": "B: 今天有行李要托運嗎？"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-dialogue-airport-001.t05",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-dialogue-airport-001.t05",
              "translation": "A: 有，我有一件行李。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-dialogue-airport-001.t06",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-dialogue-airport-001.t06",
              "translation": "B: 這是您的登機證。五號登機門。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-dialogue-airport-001.t07",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-dialogue-airport-001.t07",
              "translation": "A: 幾點開始登機？"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-dialogue-airport-001.t08",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-dialogue-airport-001.t08",
              "translation": "B: 九點四十五分登機。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-dialogue-airport-001.t09",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-dialogue-airport-001.t09",
              "translation": "A: 非常謝謝您。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-dialogue-airport-001.t10",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-dialogue-airport-001.t10",
              "translation": "B: 祝你旅途愉快。"
            }
          ]
        }
      ]
    },
    {
      "source_id": "src.en.r250.en-a1-r250-dialogue-restaurant-002",
      "title": "Ordering at a Restaurant",
      "summary": "",
      "blocks": [
        {
          "block_id": "en-a1-r250-dialogue-restaurant-002.t01",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-dialogue-restaurant-002.t01",
              "translation": "A: 你好。兩位，謝謝。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-dialogue-restaurant-002.t02",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-dialogue-restaurant-002.t02",
              "translation": "B: 這邊請。這是菜單。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-dialogue-restaurant-002.t03",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-dialogue-restaurant-002.t03",
              "translation": "A: 謝謝。可以給我一些水嗎？"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-dialogue-restaurant-002.t04",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-dialogue-restaurant-002.t04",
              "translation": "B: 當然。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-dialogue-restaurant-002.t05",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-dialogue-restaurant-002.t05",
              "translation": "A: 義大利麵裡面有什麼？"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-dialogue-restaurant-002.t06",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-dialogue-restaurant-002.t06",
              "translation": "B: 有番茄和起司。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-dialogue-restaurant-002.t07",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-dialogue-restaurant-002.t07",
              "translation": "A: 聽起來不錯。我要一份義大利麵。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-dialogue-restaurant-002.t08",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-dialogue-restaurant-002.t08",
              "translation": "B: 另一位呢？"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-dialogue-restaurant-002.t09",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-dialogue-restaurant-002.t09",
              "translation": "A: 一份沙拉。"
            }
          ]
        },
        {
          "block_id": "en-a1-r250-dialogue-restaurant-002.t10",
          "sentences": [
            {
              "sentence_id": "sent.en-a1-r250-dialogue-restaurant-002.t10",
              "translation": "B: 我馬上幫您送上。"
            }
          ]
        }
      ]
    }
  ]
}
