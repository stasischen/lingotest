{
  "index": {
    "src.en.r250.en-a1-r250-article-ticket-001": {
      "sentences": [
        {
          "id": "sent.en-a1-r250-article-ticket-001.u01",
          "translation": "我在火車站。"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u02",
          "translation": "我需要一張去巴黎的車票。"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u03",
          "translation": "我走到售票窗口。"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u04",
          "translation": "我要一張去巴黎的車票。"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u05",
          "translation": "二十歐元。"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u06",
          "translation": "我刷卡付款。"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u07",
          "translation": "櫃檯人員把車票給我。"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u08",
          "translation": "火車十點從三號月台出發。"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u09",
          "translation": "我問幾點到。"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u10",
          "translation": "下午兩點到。"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u11",
          "translation": "我問車上有沒有吃的。"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u12",
          "translation": "櫃檯人員說有一間小咖啡廳。"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u13",
          "translation": "我已經準備好出發了。"
        }
      ]
    },
    "src.en.r250.en-a1-r250-article-hotel-002": {
      "sentences": [
        {
          "id": "sent.en-a1-r250-article-hotel-002.u01",
          "translation": "我在飯店。"
        },
        {
          "id": "sent.en-a1-r250-article-hotel-002.u02",
          "translation": "我有訂房。"
        },
        {
          "id": "sent.en-a1-r250-article-hotel-002.u03",
          "translation": "我的名字是安娜．史密斯。"
        },
        {
          "id": "sent.en-a1-r250-article-hotel-002.u04",
          "translation": "我把護照給櫃檯人員。"
        },
        {
          "id": "sent.en-a1-r250-article-hotel-002.u05",
          "translation": "我的房間在二樓。"
        },
        {
          "id": "sent.en-a1-r250-article-hotel-002.u06",
          "translation": "櫃檯人員給我房卡。"
        },
        {
          "id": "sent.en-a1-r250-article-hotel-002.u07",
          "translation": "房間很漂亮。"
        },
        {
          "id": "sent.en-a1-r250-article-hotel-002.u08",
          "translation": "我想要水。"
        },
        {
          "id": "sent.en-a1-r250-article-hotel-002.u09",
          "translation": "櫃檯人員給我一瓶水。"
        },
        {
          "id": "sent.en-a1-r250-article-hotel-002.u10",
          "translation": "我問早餐的事。"
        },
        {
          "id": "sent.en-a1-r250-article-hotel-002.u11",
          "translation": "早餐七點在餐廳吃。"
        },
        {
          "id": "sent.en-a1-r250-article-hotel-002.u12",
          "translation": "退房時間是十一點。"
        }
      ]
    },
    "src.en.r250.en-a1-r250-dialogue-airport-001": {
      "sentences": [
        {
          "id": "sent.en-a1-r250-dialogue-airport-001.t01",
          "translation": "A: 你好。我想辦理登機手續。"
        },
        {
          "id": "sent.en-a1-r250-dialogue-airport-001.t02",
          "translation": "B: 可以看一下您的護照嗎？"
        },
        {
          "id": "sent.en-a1-r250-dialogue-airport-001.t03",
          "translation": "A: 給您。"
        },
        {
          "id": "sent.en-a1-r250-dialogue-airport-001.t04",
          "translation": "B: 今天有行李要托運嗎？"
        },
        {
          "id": "sent.en-a1-r250-dialogue-airport-001.t05",
          "translation": "A: 有，我有一件行李。"
        },
        {
          "id": "sent.en-a1-r250-dialogue-airport-001.t06",
          "translation": "B: 這是您的登機證。五號登機門。"
        },
        {
          "id": "sent.en-a1-r250-dialogue-airport-001.t07",
          "translation": "A: 幾點開始登機？"
        },
        {
          "id": "sent.en-a1-r250-dialogue-airport-001.t08",
          "translation": "B: 九點四十五分登機。"
        },
        {
          "id": "sent.en-a1-r250-dialogue-airport-001.t09",
          "translation": "A: 非常謝謝您。"
        },
        {
          "id": "sent.en-a1-r250-dialogue-airport-001.t10",
          "translation": "B: 祝你旅途愉快。"
        }
      ]
    },
    "src.en.r250.en-a1-r250-dialogue-restaurant-002": {
      "sentences": [
        {
          "id": "sent.en-a1-r250-dialogue-restaurant-002.t01",
          "translation": "A: 你好。兩位，謝謝。"
        },
        {
          "id": "sent.en-a1-r250-dialogue-restaurant-002.t02",
          "translation": "B: 這邊請。這是菜單。"
        },
        {
          "id": "sent.en-a1-r250-dialogue-restaurant-002.t03",
          "translation": "A: 謝謝。可以給我一些水嗎？"
        },
        {
          "id": "sent.en-a1-r250-dialogue-restaurant-002.t04",
          "translation": "B: 當然。"
        },
        {
          "id": "sent.en-a1-r250-dialogue-restaurant-002.t05",
          "translation": "A: 義大利麵裡面有什麼？"
        },
        {
          "id": "sent.en-a1-r250-dialogue-restaurant-002.t06",
          "translation": "B: 有番茄和起司。"
        },
        {
          "id": "sent.en-a1-r250-dialogue-restaurant-002.t07",
          "translation": "A: 聽起來不錯。我要一份義大利麵。"
        },
        {
          "id": "sent.en-a1-r250-dialogue-restaurant-002.t08",
          "translation": "B: 另一位呢？"
        },
        {
          "id": "sent.en-a1-r250-dialogue-restaurant-002.t09",
          "translation": "A: 一份沙拉。"
        },
        {
          "id": "sent.en-a1-r250-dialogue-restaurant-002.t10",
          "translation": "B: 我馬上幫您送上。"
        }
      ]
    }
  }
}
