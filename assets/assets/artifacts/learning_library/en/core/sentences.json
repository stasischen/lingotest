              "pos": "n"
            }
          ],
          "speaker": "A"
        },
        {
          "id": "sent.en-a1-r250-dialogue-airport-001.t02",
          "surface": "B: Can I see your passport, please?",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "B"
        },
        {
          "id": "sent.en-a1-r250-dialogue-airport-001.t03",
          "surface": "A: Here you are.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "A"
        },
        {
          "id": "sent.en-a1-r250-dialogue-airport-001.t04",
          "surface": "B: Are you checking any bags today?",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "B"
        },
        {
          "id": "sent.en-a1-r250-dialogue-airport-001.t05",
          "surface": "A: Yes, I have one bag.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "A"
        },
        {
          "id": "sent.en-a1-r250-dialogue-airport-001.t06",
          "surface": "B: Here is your boarding pass. Gate five.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "B"
        },
        {
          "id": "sent.en-a1-r250-dialogue-airport-001.t07",
          "surface": "A: What time does boarding start?",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "A"
        },
        {
          "id": "sent.en-a1-r250-dialogue-airport-001.t08",
          "surface": "B: Boarding is at nine forty-five.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "B"
        },
        {
          "id": "sent.en-a1-r250-dialogue-airport-001.t09",
          "surface": "A: Thank you very much.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "A"
        },
        {
          "id": "sent.en-a1-r250-dialogue-airport-001.t10",
          "surface": "B: Have a good flight.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "B"
        }
      ]
    },
    "src.en.r250.en-a1-r250-dialogue-restaurant-002": {
      "sentences": [
        {
          "id": "sent.en-a1-r250-dialogue-restaurant-002.t01",
          "surface": "A: Hello. A table for two, please.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "A"
        },
        {
          "id": "sent.en-a1-r250-dialogue-restaurant-002.t02",
          "surface": "B: This way, please. Here are the menus.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "B"
        },
        {
          "id": "sent.en-a1-r250-dialogue-restaurant-002.t03",
          "surface": "A: Thank you. Can I have some water?",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "A"
        },
        {
          "id": "sent.en-a1-r250-dialogue-restaurant-002.t04",
          "surface": "B: Of course.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "B"
        },
        {
          "id": "sent.en-a1-r250-dialogue-restaurant-002.t05",
          "surface": "A: What is in the pasta?",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "A"
        },
        {
          "id": "sent.en-a1-r250-dialogue-restaurant-002.t06",
          "surface": "B: It has tomato and cheese.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "B"
        },
        {
          "id": "sent.en-a1-r250-dialogue-restaurant-002.t07",
          "surface": "A: That sounds good. I'd like the pasta, please.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "A"
        },
        {
          "id": "sent.en-a1-r250-dialogue-restaurant-002.t08",
          "surface": "B: And for the other person?",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "B"
        },
        {
          "id": "sent.en-a1-r250-dialogue-restaurant-002.t09",
          "surface": "A: A salad, please.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "A"
        },
        {
          "id": "sent.en-a1-r250-dialogue-restaurant-002.t10",
          "surface": "B: I'll bring your food right out.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "B"
        }
      ]
