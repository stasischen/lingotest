    "src.en.r250.en-a1-r250-article-ticket-001": {
      "sentences": [
        {
          "id": "sent.en-a1-r250-article-ticket-001.u01",
          "surface": "I am at the train station.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "paragraph_id": "en-a1-r250-article-ticket-001"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u02",
          "surface": "I need a ticket to Paris.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "paragraph_id": "en-a1-r250-article-ticket-001"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u03",
          "surface": "I go to the ticket window.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "paragraph_id": "en-a1-r250-article-ticket-001"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u04",
          "surface": "I ask for one ticket to Paris.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "paragraph_id": "en-a1-r250-article-ticket-001"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u05",
          "surface": "It is twenty euros.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "paragraph_id": "en-a1-r250-article-ticket-001"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u06",
          "surface": "I pay by card.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "paragraph_id": "en-a1-r250-article-ticket-001"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u07",
          "surface": "The clerk gives me my ticket.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "paragraph_id": "en-a1-r250-article-ticket-001"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u08",
          "surface": "The train leaves at ten from platform three.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "paragraph_id": "en-a1-r250-article-ticket-001"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u09",
          "surface": "I ask what time it arrives.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "paragraph_id": "en-a1-r250-article-ticket-001"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u10",
          "surface": "It arrives at two in the afternoon.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "paragraph_id": "en-a1-r250-article-ticket-001"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u11",
          "surface": "I ask about food on the train.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "paragraph_id": "en-a1-r250-article-ticket-001"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u12",
          "surface": "The clerk says there is a small cafe.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "paragraph_id": "en-a1-r250-article-ticket-001"
        },
        {
          "id": "sent.en-a1-r250-article-ticket-001.u13",
          "surface": "I am ready for my trip.",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "paragraph_id": "en-a1-r250-article-ticket-001"
        }
      ]
    },
