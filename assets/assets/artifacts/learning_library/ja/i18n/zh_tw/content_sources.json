{
  "sources": [
    {
      "source_id": "src.ja.r250.ja-a1-r250-article-ticket-001",
      "title": "東京へ行く切符",
      "summary": "",
      "blocks": [
        {
          "block_id": "ja-a1-r250-article-ticket-001.u01",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-article-ticket-001.u01",
              "translation": "今天要去東京。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-article-ticket-001.u02",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-article-ticket-001.u02",
              "translation": "到了車站。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-article-ticket-001.u03",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-article-ticket-001.u03",
              "translation": "在車站買車票。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-article-ticket-001.u04",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-article-ticket-001.u04",
              "translation": "走到自動售票機。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-article-ticket-001.u05",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-article-ticket-001.u05",
              "translation": "選擇目的地。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-article-ticket-001.u06",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-article-ticket-001.u06",
              "translation": "投錢。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-article-ticket-001.u07",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-article-ticket-001.u07",
              "translation": "車票出來了。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-article-ticket-001.u08",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-article-ticket-001.u08",
              "translation": "拿車票。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-article-ticket-001.u09",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-article-ticket-001.u09",
              "translation": "通過剪票口。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-article-ticket-001.u10",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-article-ticket-001.u10",
              "translation": "在月台等火車。"
            }
          ]
        }
      ]
    },
    {
      "source_id": "src.ja.r250.ja-a1-r250-article-hotel-002",
      "title": "ホテルでチェックイン",
      "summary": "",
      "blocks": [
        {
          "block_id": "ja-a1-r250-article-hotel-002.u01",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-article-hotel-002.u01",
              "translation": "我到了飯店。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-article-hotel-002.u02",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-article-hotel-002.u02",
              "translation": "在櫃台辦理入住手續。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-article-hotel-002.u03",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-article-hotel-002.u03",
              "translation": "說了名字。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-article-hotel-002.u04",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-article-hotel-002.u04",
              "translation": "出示了護照。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-article-hotel-002.u05",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-article-hotel-002.u05",
              "translation": "拿到了房間鑰匙。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-article-hotel-002.u06",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-article-hotel-002.u06",
              "translation": "房間在三樓。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-article-hotel-002.u07",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-article-hotel-002.u07",
              "translation": "搭電梯上去。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-article-hotel-002.u08",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-article-hotel-002.u08",
              "translation": "房間很乾淨。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-article-hotel-002.u09",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-article-hotel-002.u09",
              "translation": "退房時間是十一點。"
            }
          ]
        }
      ]
    },
    {
      "source_id": "src.ja.r250.ja-a1-r250-dialogue-airport-001",
      "title": "空港でチェックイン",
      "summary": "",
      "blocks": [
        {
          "block_id": "ja-a1-r250-dialogue-airport-001.t01",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-dialogue-airport-001.t01",
              "translation": "A: 不好意思，我想辦理登機手續。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-dialogue-airport-001.t02",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-dialogue-airport-001.t02",
              "translation": "B: 請出示您的護照。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-dialogue-airport-001.t03",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-dialogue-airport-001.t03",
              "translation": "A: 好的，請看。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-dialogue-airport-001.t04",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-dialogue-airport-001.t04",
              "translation": "B: 您要靠窗還是靠走道的座位？"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-dialogue-airport-001.t05",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-dialogue-airport-001.t05",
              "translation": "A: 靠窗的，謝謝。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-dialogue-airport-001.t06",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-dialogue-airport-001.t06",
              "translation": "B: 好的。您有行李要托運嗎？"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-dialogue-airport-001.t07",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-dialogue-airport-001.t07",
              "translation": "A: 有，這個行李箱。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-dialogue-airport-001.t08",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-dialogue-airport-001.t08",
              "translation": "B: 我幫您托運。登機門在五號。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-dialogue-airport-001.t09",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-dialogue-airport-001.t09",
              "translation": "A: 謝謝。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-dialogue-airport-001.t10",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-dialogue-airport-001.t10",
              "translation": "B: 祝您旅途愉快。"
            }
          ]
        }
      ]
    },
    {
      "source_id": "src.ja.r250.ja-a1-r250-dialogue-restaurant-002",
      "title": "レストランで注文",
      "summary": "",
      "blocks": [
        {
          "block_id": "ja-a1-r250-dialogue-restaurant-002.t01",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-dialogue-restaurant-002.t01",
              "translation": "A: 不好意思，請問有什麼推薦的？"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-dialogue-restaurant-002.t02",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-dialogue-restaurant-002.t02",
              "translation": "B: 今天推薦壽司套餐。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-dialogue-restaurant-002.t03",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-dialogue-restaurant-002.t03",
              "translation": "A: 那我要這個。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-dialogue-restaurant-002.t04",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-dialogue-restaurant-002.t04",
              "translation": "B: 請問要喝點什麼？"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-dialogue-restaurant-002.t05",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-dialogue-restaurant-002.t05",
              "translation": "A: 請給我茶。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-dialogue-restaurant-002.t06",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-dialogue-restaurant-002.t06",
              "translation": "B: 好的，請稍等。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-dialogue-restaurant-002.t07",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-dialogue-restaurant-002.t07",
              "translation": "A: 不好意思，也請給我水。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-dialogue-restaurant-002.t08",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-dialogue-restaurant-002.t08",
              "translation": "B: 好的，馬上幫您送來。"
            }
          ]
        },
        {
          "block_id": "ja-a1-r250-dialogue-restaurant-002.t09",
          "sentences": [
            {
              "sentence_id": "sent.ja-a1-r250-dialogue-restaurant-002.t09",
              "translation": "A: 謝謝。"
            }
          ]
        }
      ]
    }
  ]
}
