          "atoms": [],
          "speaker": "A"
        },
        {
          "id": "sent.ja-a1-r250-dialogue-restaurant-002.t02",
          "surface": "B: 今日のすしセットがおすすめです。",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "B"
        },
        {
          "id": "sent.ja-a1-r250-dialogue-restaurant-002.t03",
          "surface": "A: じゃあ、これをください。",
          "vocab_refs": [],
