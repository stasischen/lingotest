    "src.ja.r250.ja-a1-r250-dialogue-airport-001": {
      "sentences": [
        {
          "id": "sent.ja-a1-r250-dialogue-airport-001.t01",
          "surface": "A: すみません、チェックインをお願いします。",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "A"
        },
        {
          "id": "sent.ja-a1-r250-dialogue-airport-001.t02",
          "surface": "B: パスポートを見せてください。",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "B"
        },
        {
          "id": "sent.ja-a1-r250-dialogue-airport-001.t03",
          "surface": "A: はい、どうぞ。",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "A"
        },
        {
          "id": "sent.ja-a1-r250-dialogue-airport-001.t04",
          "surface": "B: 窓側と通路側、どちらですか。",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "B"
        },
        {
          "id": "sent.ja-a1-r250-dialogue-airport-001.t05",
          "surface": "A: 窓側をお願いします。",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "A"
        },
        {
          "id": "sent.ja-a1-r250-dialogue-airport-001.t06",
          "surface": "B: かしこまりました。荷物はありますか。",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "B"
        },
        {
          "id": "sent.ja-a1-r250-dialogue-airport-001.t07",
          "surface": "A: はい、このスーツケースです。",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "A"
        },
        {
          "id": "sent.ja-a1-r250-dialogue-airport-001.t08",
          "surface": "B: お預かりします。ゲートは5番です。",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "B"
        },
        {
          "id": "sent.ja-a1-r250-dialogue-airport-001.t09",
          "surface": "A: どうも。",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "A"
        },
        {
          "id": "sent.ja-a1-r250-dialogue-airport-001.t10",
          "surface": "B: どうぞ、よいご旅行を。",
          "vocab_refs": [],
          "topic_refs": [],
          "atoms": [],
          "speaker": "B"
        }
      ]
    },
    "src.ja.r250.ja-a1-r250-dialogue-restaurant-002": {
