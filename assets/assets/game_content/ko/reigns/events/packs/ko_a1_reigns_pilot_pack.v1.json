      "difficulty": 2,
      "setup": {
        "zh_tw": "同學想約你明天一起讀韓文，你需要確認時間。",
        "en": "A classmate wants to study Korean with you tomorrow, and you need to confirm the time."
      },
      "npc_speaker_id": "classmate",
      "npc_utterance": {
        "ko": "내일 만날까요?",
        "zh_tw": "明天要見面嗎？",
        "en": "Shall we meet tomorrow?"
      },
      "choices": [
        {
          "choice_id": "confirm_three_pm",
          "text": {
            "ko": "세 시에 만날 거예요.",
            "zh_tw": "三點見。",
            "en": "I will meet at three."
          },
          "result": "success",
          "reaction": {
            "zh_tw": "同學把三點記在行事曆裡。",
            "en": "The classmate writes three o'clock in the calendar."
          },
          "pal_tip": {
            "zh_tw": "A1 可以開始用「-ㄹ 거예요」說接下來的安排。",
            "en": "At A1, you can use -ㄹ 거예요 to state a coming plan."
          }
        },
        {
          "choice_id": "past_time_mismatch",
          "text": {
            "ko": "어제 만났어요.",
            "zh_tw": "昨天見面了。",
            "en": "We met yesterday."
          },
          "result": "error",
          "error_type": "tense_mismatch",
          "reaction": {
            "zh_tw": "同學以為你在說過去的事，沒有得到明天的時間。",
            "en": "The classmate thinks you are talking about the past and does not get tomorrow's time."
