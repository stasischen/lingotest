{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lingo.local/schemas/reigns_event_pack.v1.json",
  "title": "Lingo Reigns Event Pack",
  "type": "object",
  "required": [
    "schema_version",
    "pack_id",
    "status",
    "target_lang",
    "support_lang",
    "level",
    "events"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "reigns_event_pack.v1"
    },
    "pack_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["seed", "draft", "reviewed", "production_candidate"]
    },
    "target_lang": {
      "const": "ko"
    },
    "support_lang": {
      "const": "zh_tw"
    },
    "level": {
      "type": "string",
      "enum": ["A0", "A1"]
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/event"
      }
    }
  },
  "$defs": {
    "localized_text": {
      "type": "object",
      "required": ["zh_tw", "en"],
      "additionalProperties": false,
      "properties": {
        "zh_tw": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string",
          "minLength": 1
        },
        "ko": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "coverage": {
      "type": "object",
      "required": ["vocab", "grammar", "patterns", "scene_tags"],
      "additionalProperties": false,
      "properties": {
        "vocab": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "grammar": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "patterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "scene_tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "choice": {
      "type": "object",
      "required": ["choice_id", "text", "result", "reaction", "pal_tip"],
      "additionalProperties": false,
      "properties": {
        "choice_id": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "$ref": "#/$defs/localized_text"
        },
        "result": {
          "type": "string",
          "enum": ["success", "error"]
        },
        "error_type": {
          "type": "string",
          "minLength": 1
        },
        "reaction": {
          "$ref": "#/$defs/localized_text"
        },
        "pal_tip": {
          "$ref": "#/$defs/localized_text"
        }
      }
    },
    "event": {
      "type": "object",
      "required": [
        "event_id",
        "level",
        "scene_type",
        "register",
        "difficulty",
        "setup",
        "npc_speaker_id",
        "npc_utterance",
        "choices",
        "coverage",
        "tags",
        "prerequisites"
      ],
      "additionalProperties": false,
      "properties": {
        "event_id": {
          "type": "string",
          "minLength": 1
        },
        "level": {
          "type": "string",
          "enum": ["A0", "A1"]
        },
        "scene_type": {
          "type": "string",
          "minLength": 1
        },
        "register": {
          "type": "string",
          "minLength": 1
        },
        "difficulty": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "setup": {
          "$ref": "#/$defs/localized_text"
        },
        "npc_speaker_id": {
          "type": "string",
          "minLength": 1
        },
        "npc_utterance": {
          "$ref": "#/$defs/localized_text"
        },
        "choices": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "$ref": "#/$defs/choice"
          }
        },
        "coverage": {
          "$ref": "#/$defs/coverage"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "prerequisites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
