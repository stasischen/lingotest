{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lingo.local/schemas/reigns_coverage_matrix.v1.json",
  "title": "Lingo Reigns Coverage Matrix",
  "type": "object",
  "required": [
    "schema_version",
    "matrix_id",
    "level",
    "target_event_count",
    "status",
    "event_buckets",
    "coverage_targets"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "reigns_coverage_matrix.v1"
    },
    "matrix_id": {
      "type": "string",
      "minLength": 1
    },
    "level": {
      "type": "string",
      "enum": ["A0", "A1"]
    },
    "target_event_count": {
      "type": "integer",
      "const": 100
    },
    "status": {
      "type": "string",
      "enum": ["seed", "draft", "reviewed"]
    },
    "event_buckets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/event_bucket"
      }
    },
    "coverage_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/coverage_target"
      }
    }
  },
  "$defs": {
    "string_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "event_bucket": {
      "type": "object",
      "required": [
        "bucket_id",
        "title",
        "event_count",
        "scene_tags",
        "primary_targets",
        "notes"
      ],
      "additionalProperties": false,
      "properties": {
        "bucket_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "event_count": {
          "type": "integer",
          "minimum": 1
        },
        "scene_tags": {
          "$ref": "#/$defs/string_list"
        },
        "primary_targets": {
          "$ref": "#/$defs/string_list"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "coverage_target": {
      "type": "object",
      "required": [
        "target_id",
        "kind",
        "required_event_count",
        "scene_tags",
        "covered_by"
      ],
      "additionalProperties": false,
      "properties": {
        "target_id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["pattern", "grammar", "vocab_set", "scene"]
        },
        "required_event_count": {
          "type": "integer",
          "minimum": 1
        },
        "scene_tags": {
          "$ref": "#/$defs/string_list"
        },
        "covered_by": {
          "$ref": "#/$defs/string_list"
        }
      }
    }
  }
}
