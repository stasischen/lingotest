            "sent.src.fr.dialogue.travel_taxi_destination.t2_npc": {
              "translation": "到中央飯店，對嗎？"
            },
            "sent.src.fr.dialogue.travel_taxi_destination.t2_learner": {
              "translation": "對，到中央飯店。"
            },
            "sent.src.fr.dialogue.travel_taxi_destination.t3_npc": {
              "translation": "大約十分鐘。"
            },
            "sent.src.fr.dialogue.travel_taxi_destination.t3_learner": {
              "translation": "好的，謝謝。"
