        "src.fr.dialogue.food_coffee_ordering": {
          "sentences": {
            "sent.src.fr.dialogue.food_coffee_ordering.t1_npc": {
              "translation": "店員在問你想點什麼。"
            },
            "sent.src.fr.dialogue.food_coffee_ordering.t1_learner": {
              "translation": "我想要一杯牛奶咖啡，謝謝。"
            },
            "sent.src.fr.dialogue.food_coffee_ordering.t2_npc": {
              "translation": "店員在問你要內用還是外帶。"
            },
            "sent.src.fr.dialogue.food_coffee_ordering.t2_learner": {
              "translation": "外帶，謝謝。"
            },
            "sent.src.fr.dialogue.food_coffee_ordering.t3_npc": {
              "translation": "店員在確認你的訂單。"
            },
            "sent.src.fr.dialogue.food_coffee_ordering.t3_learner": {
              "translation": "對，就是這樣。"
            },
            "sent.src.fr.dialogue.food_coffee_ordering.t4_npc": {
              "translation": "店員告訴你金額，並請你在這裡付款。"
            },
            "sent.src.fr.dialogue.food_coffee_ordering.t4_learner": {
              "translation": "好的，謝謝。"
            }
          }
        },
        "src.fr.dialogue.food_restaurant_ordering": {
