            },
            "sent.src.fr.dialogue.digital_battery_charging.t2_learner": {
              "translation": "插座在哪裡？"
            },
            "sent.src.fr.dialogue.digital_battery_charging.t3_npc": {
              "translation": "插座在桌子旁邊。"
            },
            "sent.src.fr.dialogue.digital_battery_charging.t3_learner": {
              "translation": "在桌子旁邊嗎？"
            },
            "sent.src.fr.dialogue.digital_battery_charging.t4_npc": {
              "translation": "對，就在那裡。"
            },
            "sent.src.fr.dialogue.digital_battery_charging.t4_learner": {
              "translation": "謝謝。"
            }
          }
        },
        "src.fr.dialogue.digital_wifi_connect": {
          "sentences": {
            "sent.src.fr.dialogue.digital_wifi_connect.t1_npc": {
              "translation": "關於 Wi-Fi，請說。"
            },
            "sent.src.fr.dialogue.digital_wifi_connect.t1_learner": {
              "translation": "wifi 密碼是什麼？"
            },
            "sent.src.fr.dialogue.digital_wifi_connect.t2_npc": {
              "translation": "密碼是 cafe2026。"
            },
            "sent.src.fr.dialogue.digital_wifi_connect.t2_learner": {
              "translation": "謝謝，我試一下。"
            },
            "sent.src.fr.dialogue.digital_wifi_connect.t3_npc": {
              "translation": "可以用嗎？"
            },
            "sent.src.fr.dialogue.digital_wifi_connect.t3_learner": {
              "translation": "不，連不上。"
            },
            "sent.src.fr.dialogue.digital_wifi_connect.t4_npc": {
