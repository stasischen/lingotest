        "src.fr.dialogue.convenience_payment_card_cash": {
          "sentences": {
            "sent.src.fr.dialogue.convenience_payment_card_cash.t1_npc": {
              "translation": "四歐元。刷卡還是付現？"
            },
            "sent.src.fr.dialogue.convenience_payment_card_cash.t1_learner": {
              "translation": "刷卡，謝謝。"
            },
            "sent.src.fr.dialogue.convenience_payment_card_cash.t2_npc": {
              "translation": "好的。請把卡靠近感應。"
            },
            "sent.src.fr.dialogue.convenience_payment_card_cash.t2_learner": {
              "translation": "好的，謝謝。"
            },
            "sent.src.fr.dialogue.convenience_payment_card_cash.t3_npc": {
              "translation": "您要收據嗎？"
            },
            "sent.src.fr.dialogue.convenience_payment_card_cash.t3_learner": {
              "translation": "不用，謝謝。"
            },
            "sent.src.fr.dialogue.convenience_payment_card_cash.t4_npc": {
              "translation": "好了，沒問題。謝謝。"
            },
            "sent.src.fr.dialogue.convenience_payment_card_cash.t4_learner": {
              "translation": "謝謝。"
            }
          }
        },
        "src.fr.dialogue.core_repair_repeat_slowly": {
