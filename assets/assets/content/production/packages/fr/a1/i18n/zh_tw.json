        "src.fr.dialogue.daily_self_intro": {
          "sentences": {
            "sent.src.fr.dialogue.daily_self_intro.t1_npc": {
              "translation": "嗨，我是 Camille。你呢？"
            },
            "sent.src.fr.dialogue.daily_self_intro.t1_learner": {
              "translation": "嗨，我是 Alex。"
            },
            "sent.src.fr.dialogue.daily_self_intro.t2_npc": {
              "translation": "很高興認識你，Alex。你來自哪裡？"
            },
            "sent.src.fr.dialogue.daily_self_intro.t2_learner": {
              "translation": "我來自台北。"
            },
            "sent.src.fr.dialogue.daily_self_intro.t3_npc": {
              "translation": "太好了。你在學法語嗎？"
            },
            "sent.src.fr.dialogue.daily_self_intro.t3_learner": {
              "translation": "對，我在學法語。"
            },
            "sent.src.fr.dialogue.daily_self_intro.t4_npc": {
              "translation": "很好。很高興認識你。"
            },
            "sent.src.fr.dialogue.daily_self_intro.t4_learner": {
              "translation": "我也是。"
            }
          }
        },
        "src.fr.dialogue.digital_battery_charging": {
          "sentences": {
            "sent.src.fr.dialogue.digital_battery_charging.t1_npc": {
              "translation": "您好，我可以幫您嗎？"
            },
            "sent.src.fr.dialogue.digital_battery_charging.t1_learner": {
              "translation": "我可以在這裡充手機嗎？"
