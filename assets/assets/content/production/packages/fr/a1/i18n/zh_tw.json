        "src.fr.dialogue.daily_meet_friend": {
          "sentences": {
            "sent.src.fr.dialogue.daily_meet_friend.t1_npc": {
              "translation": "嗨！你是 Alex 嗎？"
            },
            "sent.src.fr.dialogue.daily_meet_friend.t1_learner": {
              "translation": "對，是我。"
            },
            "sent.src.fr.dialogue.daily_meet_friend.t2_npc": {
              "translation": "太好了。你準備好了嗎？"
            },
            "sent.src.fr.dialogue.daily_meet_friend.t2_learner": {
              "translation": "對，我準備好了。"
            },
            "sent.src.fr.dialogue.daily_meet_friend.t3_npc": {
              "translation": "很好。我們去咖啡店。"
            },
            "sent.src.fr.dialogue.daily_meet_friend.t3_learner": {
              "translation": "好，走吧。"
            },
            "sent.src.fr.dialogue.daily_meet_friend.t4_npc": {
              "translation": "朋友問要出發了嗎。"
            },
            "sent.src.fr.dialogue.daily_meet_friend.t4_learner": {
              "translation": "好，我們走吧。"
            }
          }
        },
