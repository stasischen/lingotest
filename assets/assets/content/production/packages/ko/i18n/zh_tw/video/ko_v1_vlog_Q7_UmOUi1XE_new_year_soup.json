{
  "id": "Q7_UmOUi1XE",
  "translations": {
    "v_001": "大家好。我是再臨。",
    "v_002": "下週。下週是",
    "v_003": "春節。是春節。",
    "v_004": "春節是農曆 1 月 1 日。",
    "v_005": "韓國人在春節會吃年糕湯。",
    "v_006": "年糕湯",
    "v_007": "今天要來做年糕湯。",
    "v_008": "那麼要開始了嗎？",
    "v_009": "這是材料。材料。",
    "v_010": "這是年糕。年糕。",
    "v_011": "這是餃子。餃子。",
    "v_012": "這是牛骨高湯。牛骨高湯。",
    "v_013": "這是大蔥。大蔥。",
    "v_014": "這是雞蛋。雞蛋。",
    "v_015": "準備材料。",
    "v_016": "切大蔥。切大蔥。",
    "v_017": "打蛋。打蛋。",
    "v_018": "然後打散雞蛋。",
    "v_019": "仔細打散。",
    "v_020": "年糕和餃子已經事先解凍了。",
    "v_021": "已經解凍了。",
    "v_022": "這是鮮肉餃子。",
    "v_023": "這是泡菜餃子。",
    "v_024": "現在拿出鍋子。",
    "v_025": "把鍋子放上去。",
    "v_026": "放上鍋子。",
    "v_027": "開火。",
    "v_028": "把牛骨高湯倒進鍋裡。",
    "v_029": "煮沸。",
    "v_030": "現在正在煮沸。",
    "v_031": "加入一杯水。",
    "v_032": "水在大滾。",
    "v_033": "正在大滾著。",
    "v_034": "現在放入年糕。",
    "v_035": "攪拌。攪拌。",
    "v_036": "也放入餃子。",
    "v_037": "放入一匙鹽巴。",
    "v_038": "再煮一會兒。",
    "v_039": "現在放入大蔥。",
    "v_040": "也放入雞蛋。",
    "v_041": "再煮一下子。",
    "v_042": "關火。",
    "v_043": "完成了。",
    "v_044": "盛在碗裡。盛進碗。",
    "v_045": "冒煙了。",
    "v_046": "看起來好吃嗎？",
    "v_047": "鏘鏘～完成了。",
    "v_048": "現在來吃吃看。",
    "v_049": "嗯～",
    "v_050": "好吃。太好吃了。",
    "v_051": "今天做了超簡單的年糕湯。",
    "v_052": "在韓國，吃了年糕湯就代表長了一歲。",
    "v_053": "大家家鄉在過節時會吃什麼呢？",
    "v_054": "節慶食物是什麼呢？",
    "v_055": "請留言告訴我。",
    "v_056": "那麼各位，祝大家新年快樂。",
    "v_057": "再見～"
  }
