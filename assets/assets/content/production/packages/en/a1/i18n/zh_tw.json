        "kg.grammar.en.copula.be_am_is_are.v1": {
          "id": "kg.grammar.en.copula.be_am_is_are.v1",
          "kind": "grammar",
          "subcategory": "copula",
          "level": "A1",
          "surface": "be (am / is / are)",
          "tags": [
            "beginner",
            "copula",
            "present"
          ],
          "example_sentence_refs": [
            "sent.src.en.a1.l01.001",
            "sent.src.en.a1.l01.002",
            "sent.src.en.a1.l01.003",
            "sent.src.en.a1.l01.005",
            "sent.src.en.a1.l01.006",
            "sent.src.en.a1.l01.007"
          ],
          "learner_language": "zh_tw",
          "title": "be 動詞（am / is / are）",
          "description": "be 動詞根據主詞不同而變化，是英語中最基本的動詞。",
          "explanation_md": "**be** 動詞根據主詞變化：\n\n| 主詞 | be 動詞 |\n|------|--------|\n| I | am |\n| he / she / it | is |\n| you / we / they | are |\n\n**用法：**\n1. 表示身分：I **am** a student.\n2. 表示狀態：She **is** happy.\n3. 表示位置：We **are** in class.\n\n**否定句：** 在 be 動詞後加 not\n- I **am not** a teacher.\n- She **is not** (isn't) here.\n- They **are not** (aren't) new.\n\n**疑問句：** 將 be 動詞移到主詞前面\n- **Am** I a student?\n- **Is** she happy?\n- **Are** you ready?"
        },
        "kg.grammar.en.pronouns.subject_pronouns.v1": {
