    {
      "learning_object_id": "zh_grammar_svo",
      "title_zh_tw": "主詞 + 動詞 + 受詞/補語（我, 是）",
      "explanation_md_zh_tw": "這個節點教 繁體中文 A1 的「主詞 + 動詞 + 受詞/補語」。 中文基本語序常是「主詞 + 動詞 + 受詞/補語」，例如「我買早餐」「她是學生」。先找誰做動作，再找做了什麼。 這次先認得：我、是。 讀例句時，只要能說出這個形式幫句子完成了什麼意思，就算掌握第一步。",
      "ref_id": "ZH.grammar.svo",
      "ref_item": "basic SVO word order",
      "ref_subitems": [
        "我",
        "是"
      ],
      "examples": [
        {
          "surface": "我是阿明。",
          "source_item_id": "article:zh_reading_svo_a1_v1:u001",
          "note_zh_tw": "這句直接使用「我、是」，呈現「basic SVO word order」在 A1 閱讀中的實際用法。"
        },
        {
          "surface": "我今天去學校。",
          "source_item_id": "article:zh_reading_svo_a1_v1:u002",
          "note_zh_tw": "這句直接使用「我」，呈現「basic SVO word order」在 A1 閱讀中的實際用法。"
        },
        {
          "surface": "老師是王老師。",
          "source_item_id": "article:zh_reading_svo_a1_v1:u003",
          "note_zh_tw": "這句直接使用「是」，呈現「basic SVO word order」在 A1 閱讀中的實際用法。"
        },
        {
          "surface": "我在教室看書。",
          "source_item_id": "article:zh_reading_svo_a1_v1:u004",
          "note_zh_tw": "這句直接使用「我」，呈現「basic SVO word order」在 A1 閱讀中的實際用法。"
        }
      ],
      "external_source": "TBCL Level 1",
      "source_locator": "Taiwan TBCL Level 1; Traditional Chinese denominator, not HSK",
      "source_reading_asset_id": "zh_reading_svo_a1_v1",
