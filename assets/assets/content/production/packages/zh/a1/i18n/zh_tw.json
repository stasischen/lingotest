            "sent.src.zh.dialogue.travel_taxi_destination.t2_learner": {
              "translation": "對，沒錯。"
            },
            "sent.src.zh.dialogue.travel_taxi_destination.t3_npc": {
              "translation": "好，大概十分鐘。"
            },
            "sent.src.zh.dialogue.travel_taxi_destination.t3_learner": {
              "translation": "好的。"
