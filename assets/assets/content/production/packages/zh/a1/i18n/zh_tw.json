            "sent.src.zh.dialogue.travel_ticket_buying.t3_learner": {
              "translation": "刷卡，謝謝。"
            },
            "sent.src.zh.dialogue.travel_ticket_buying.t4_npc": {
              "translation": "這是您的車票。三號月台。"
