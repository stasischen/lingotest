          "sentences": {
            "sent.src.es.dialogue.travel_taxi_destination.t1_npc": {
              "translation": "午安，我們要去哪裡？"
            },
            "sent.src.es.dialogue.travel_taxi_destination.t1_learner": {
              "translation": "到中央飯店，謝謝。"
            },
            "sent.src.es.dialogue.travel_taxi_destination.t2_npc": {
              "translation": "到中央飯店，對嗎？"
            },
            "sent.src.es.dialogue.travel_taxi_destination.t2_learner": {
              "translation": "對，到中央飯店。"
            },
            "sent.src.es.dialogue.travel_taxi_destination.t3_npc": {
              "translation": "大約十分鐘。"
            },
            "sent.src.es.dialogue.travel_taxi_destination.t3_learner": {
              "translation": "好的，謝謝。"
            },
            "sent.src.es.dialogue.travel_taxi_destination.t4_npc": {
              "translation": "我們到了。"
            },
            "sent.src.es.dialogue.travel_taxi_destination.t4_learner": {
              "translation": "非常謝謝。"
            }
          }
        },
        "src.es.dialogue.travel_ticket_buying": {
          "sentences": {
            "sent.src.es.dialogue.travel_ticket_buying.t1_npc": {
              "translation": "早安。您要去哪裡？"
            },
            "sent.src.es.dialogue.travel_ticket_buying.t1_learner": {
              "translation": "請給我一張去馬德里的票。"
            },
            "sent.src.es.dialogue.travel_ticket_buying.t2_npc": {
              "translation": "一張去馬德里的票嗎？"
            },
            "sent.src.es.dialogue.travel_ticket_buying.t2_learner": {
              "translation": "對，沒錯。"
            },
            "sent.src.es.dialogue.travel_ticket_buying.t3_npc": {
              "translation": "十二歐元。您用卡付款嗎？"
            },
            "sent.src.es.dialogue.travel_ticket_buying.t3_learner": {
              "translation": "對，用卡。"
            },
            "sent.src.es.dialogue.travel_ticket_buying.t4_npc": {
              "translation": "給您。二號月台。"
            },
            "sent.src.es.dialogue.travel_ticket_buying.t4_learner": {
              "translation": "謝謝。"
            }
          }
        }
      }
