          }
        },
        "src.it.dialogue.travel_taxi_destination": {
          "sentences": {
            "sent.src.it.dialogue.travel_taxi_destination.t1_npc": {
              "translation": "早安。要去哪裡？"
            },
            "sent.src.it.dialogue.travel_taxi_destination.t1_learner": {
              "translation": "到羅馬飯店，謝謝。"
            },
            "sent.src.it.dialogue.travel_taxi_destination.t2_npc": {
              "translation": "到羅馬飯店，對嗎？"
            },
            "sent.src.it.dialogue.travel_taxi_destination.t2_learner": {
              "translation": "對，沒錯。"
            },
            "sent.src.it.dialogue.travel_taxi_destination.t3_npc": {
              "translation": "好的。大約需要十分鐘。"
            },
            "sent.src.it.dialogue.travel_taxi_destination.t3_learner": {
              "translation": "好的。"
            },
            "sent.src.it.dialogue.travel_taxi_destination.t4_npc": {
              "translation": "到了，我們到了。"
            },
            "sent.src.it.dialogue.travel_taxi_destination.t4_learner": {
              "translation": "謝謝，祝您有美好的一天。"
            }
          }
        },
        "src.it.dialogue.travel_ticket_buying": {
          "sentences": {
            "sent.src.it.dialogue.travel_ticket_buying.t1_npc": {
              "translation": "您好，請說。"
            },
            "sent.src.it.dialogue.travel_ticket_buying.t1_learner": {
              "translation": "請給我一張到米蘭的票。"
            },
            "sent.src.it.dialogue.travel_ticket_buying.t2_npc": {
              "translation": "一張到米蘭的票，對嗎？"
            },
            "sent.src.it.dialogue.travel_ticket_buying.t2_learner": {
              "translation": "是的，沒錯。"
            },
            "sent.src.it.dialogue.travel_ticket_buying.t3_npc": {
              "translation": "十二歐元。"
            },
            "sent.src.it.dialogue.travel_ticket_buying.t3_learner": {
              "translation": "我刷卡付款。"
            },
            "sent.src.it.dialogue.travel_ticket_buying.t4_npc": {
              "translation": "這是車票。三號月台。"
            },
            "sent.src.it.dialogue.travel_ticket_buying.t4_learner": {
              "translation": "謝謝。"
            }
          }
        }
      }
