        "src.it.dialogue.food_coffee_ordering": {
          "sentences": {
            "sent.src.it.dialogue.food_coffee_ordering.t1_npc": {
              "translation": "店員在問你要點什麼。"
            },
            "sent.src.it.dialogue.food_coffee_ordering.t1_learner": {
              "translation": "一杯卡布奇諾，謝謝。"
            },
            "sent.src.it.dialogue.food_coffee_ordering.t2_npc": {
              "translation": "店員在問你要在這裡喝，還是外帶。"
            },
            "sent.src.it.dialogue.food_coffee_ordering.t2_learner": {
              "translation": "外帶，謝謝。"
            },
            "sent.src.it.dialogue.food_coffee_ordering.t3_npc": {
              "translation": "店員在確認你的訂單。"
            },
            "sent.src.it.dialogue.food_coffee_ordering.t3_learner": {
              "translation": "對，沒錯。"
            },
            "sent.src.it.dialogue.food_coffee_ordering.t4_npc": {
              "translation": "店員告訴你金額，並請你在這裡付款。"
            },
            "sent.src.it.dialogue.food_coffee_ordering.t4_learner": {
              "translation": "好的，謝謝。"
            }
          }
        },
        "src.it.dialogue.food_restaurant_ordering": {
          "sentences": {
            "sent.src.it.dialogue.food_restaurant_ordering.t1_npc": {
              "translation": "晚上好。你們準備好點餐了嗎？"
            },
            "sent.src.it.dialogue.food_restaurant_ordering.t1_learner": {
              "translation": "是的，我們兩位。"
            },
            "sent.src.it.dialogue.food_restaurant_ordering.t2_npc": {
              "translation": "你們要點什麼？"
            },
            "sent.src.it.dialogue.food_restaurant_ordering.t2_learner": {
              "translation": "我要一份番茄義大利麵，謝謝。"
            },
            "sent.src.it.dialogue.food_restaurant_ordering.t3_npc": {
              "translation": "一份番茄義大利麵，對嗎？"
            },
            "sent.src.it.dialogue.food_restaurant_ordering.t3_learner": {
              "translation": "是的，謝謝。"
            },
            "sent.src.it.dialogue.food_restaurant_ordering.t4_npc": {
              "translation": "好的。馬上為您準備。"
            },
            "sent.src.it.dialogue.food_restaurant_ordering.t4_learner": {
              "translation": "謝謝。"
            }
          }
        },
        "src.it.dialogue.hotel_checkout": {
          "sentences": {
            "sent.src.it.dialogue.hotel_checkout.t1_npc": {
              "translation": "早安。請問有什麼可以幫您？"
            },
            "sent.src.it.dialogue.hotel_checkout.t1_learner": {
              "translation": "我想退房。"
            },
            "sent.src.it.dialogue.hotel_checkout.t2_npc": {
              "translation": "好的。房號是多少？"
            },
            "sent.src.it.dialogue.hotel_checkout.t2_learner": {
              "translation": "204 號房。"
            },
            "sent.src.it.dialogue.hotel_checkout.t3_npc": {
              "translation": "很好。請把房卡交給我，好嗎？"
            },
            "sent.src.it.dialogue.hotel_checkout.t3_learner": {
              "translation": "好，房卡在這裡。"
