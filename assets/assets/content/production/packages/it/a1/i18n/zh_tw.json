        "src.it.dialogue.convenience_payment_card_cash": {
          "sentences": {
            "sent.src.it.dialogue.convenience_payment_card_cash.t1_npc": {
              "translation": "收銀員在問你要刷卡還是付現。"
            },
            "sent.src.it.dialogue.convenience_payment_card_cash.t1_learner": {
              "translation": "刷卡，謝謝。"
            },
            "sent.src.it.dialogue.convenience_payment_card_cash.t2_npc": {
              "translation": "收銀員請你插卡。"
            },
            "sent.src.it.dialogue.convenience_payment_card_cash.t2_learner": {
              "translation": "好的。"
            },
            "sent.src.it.dialogue.convenience_payment_card_cash.t3_npc": {
              "translation": "收銀員問你要不要收據。"
            },
            "sent.src.it.dialogue.convenience_payment_card_cash.t3_learner": {
              "translation": "不用，謝謝。"
            },
            "sent.src.it.dialogue.convenience_payment_card_cash.t4_npc": {
              "translation": "收銀員結束交易並祝你有美好的一天。"
            },
            "sent.src.it.dialogue.convenience_payment_card_cash.t4_learner": {
              "translation": "謝謝，再見。"
            }
          }
        },
        "src.it.dialogue.core_repair_repeat_slowly": {
          "sentences": {
            "sent.src.it.dialogue.core_repair_repeat_slowly.t1_npc": {
              "translation": "您要袋子嗎？"
            },
            "sent.src.it.dialogue.core_repair_repeat_slowly.t1_learner": {
              "translation": "可以請您再說一次嗎？"
            },
            "sent.src.it.dialogue.core_repair_repeat_slowly.t2_npc": {
              "translation": "您要袋子嗎？"
            },
            "sent.src.it.dialogue.core_repair_repeat_slowly.t2_learner": {
              "translation": "您可以說慢一點嗎？"
            },
            "sent.src.it.dialogue.core_repair_repeat_slowly.t3_npc": {
              "translation": "當然。您要袋子嗎？"
            },
            "sent.src.it.dialogue.core_repair_repeat_slowly.t3_learner": {
              "translation": "不用，謝謝。"
            },
            "sent.src.it.dialogue.core_repair_repeat_slowly.t4_npc": {
              "translation": "好的，這樣就可以了。"
            },
            "sent.src.it.dialogue.core_repair_repeat_slowly.t4_learner": {
              "translation": "謝謝。"
            }
          }
        },
        "src.it.dialogue.daily_meet_friend": {
          "sentences": {
            "sent.src.it.dialogue.daily_meet_friend.t1_npc": {
              "translation": "嗨！你到了。"
            },
            "sent.src.it.dialogue.daily_meet_friend.t1_learner": {
              "translation": "嗨，Marco！"
            },
            "sent.src.it.dialogue.daily_meet_friend.t2_npc": {
              "translation": "我們去博物館，對吧？"
            },
            "sent.src.it.dialogue.daily_meet_friend.t2_learner": {
              "translation": "對，去博物館。"
            },
            "sent.src.it.dialogue.daily_meet_friend.t3_npc": {
              "translation": "你準備好了嗎？"
            },
            "sent.src.it.dialogue.daily_meet_friend.t3_learner": {
              "translation": "對，我準備好了。"
            },
            "sent.src.it.dialogue.daily_meet_friend.t4_npc": {
              "translation": "太好了。走吧？"
            },
            "sent.src.it.dialogue.daily_meet_friend.t4_learner": {
              "translation": "走吧。"
            }
          }
        },
        "src.it.dialogue.daily_schedule_time": {
          "sentences": {
            "sent.src.it.dialogue.daily_schedule_time.t1_npc": {
              "translation": "朋友問你們幾點見面。"
            },
            "sent.src.it.dialogue.daily_schedule_time.t1_learner": {
              "translation": "三點可以。"
            },
            "sent.src.it.dialogue.daily_schedule_time.t2_npc": {
              "translation": "朋友確認今天可不可以。"
            },
            "sent.src.it.dialogue.daily_schedule_time.t2_learner": {
              "translation": "可以，今天可以。"
            },
            "sent.src.it.dialogue.daily_schedule_time.t3_npc": {
              "translation": "朋友確認三點見。"
            },
            "sent.src.it.dialogue.daily_schedule_time.t3_learner": {
              "translation": "太好了。"
            },
            "sent.src.it.dialogue.daily_schedule_time.t4_npc": {
              "translation": "朋友說待會見。"
            },
            "sent.src.it.dialogue.daily_schedule_time.t4_learner": {
              "translation": "待會見！"
            }
          }
        },
        "src.it.dialogue.daily_self_intro": {
          "sentences": {
            "sent.src.it.dialogue.daily_self_intro.t1_npc": {
              "translation": "嗨，很高興認識你！"
            },
            "sent.src.it.dialogue.daily_self_intro.t1_learner": {
              "translation": "嗨，我是 Luca。"
            },
            "sent.src.it.dialogue.daily_self_intro.t2_npc": {
              "translation": "你在學什麼語言？"
            },
            "sent.src.it.dialogue.daily_self_intro.t2_learner": {
              "translation": "我正在學義大利語。"
            },
            "sent.src.it.dialogue.daily_self_intro.t3_npc": {
              "translation": "我也是！很高興認識你。"
            },
            "sent.src.it.dialogue.daily_self_intro.t3_learner": {
              "translation": "我也很高興。"
            },
            "sent.src.it.dialogue.daily_self_intro.t4_npc": {
              "translation": "歡迎加入這個小組！"
            },
            "sent.src.it.dialogue.daily_self_intro.t4_learner": {
              "translation": "謝謝！"
            }
          }
        },
        "src.it.dialogue.digital_battery_charging": {
          "sentences": {
            "sent.src.it.dialogue.digital_battery_charging.t1_npc": {
              "translation": "您好，我可以幫您嗎？"
            },
            "sent.src.it.dialogue.digital_battery_charging.t1_learner": {
              "translation": "我可以在這裡充手機嗎？"
            },
            "sent.src.it.dialogue.digital_battery_charging.t2_npc": {
              "translation": "可以，當然。"
            },
            "sent.src.it.dialogue.digital_battery_charging.t2_learner": {
              "translation": "插座在哪裡？"
            },
            "sent.src.it.dialogue.digital_battery_charging.t3_npc": {
              "translation": "插座在窗邊。"
            },
            "sent.src.it.dialogue.digital_battery_charging.t3_learner": {
              "translation": "窗邊那裡嗎？"
            },
            "sent.src.it.dialogue.digital_battery_charging.t4_npc": {
              "translation": "對，就在那裡。"
            },
            "sent.src.it.dialogue.digital_battery_charging.t4_learner": {
              "translation": "非常謝謝。"
            }
          }
        },
        "src.it.dialogue.digital_wifi_connect": {
          "sentences": {
            "sent.src.it.dialogue.digital_wifi_connect.t1_npc": {
              "translation": "你好，請說。"
            },
            "sent.src.it.dialogue.digital_wifi_connect.t1_learner": {
              "translation": "Wi-Fi 密碼是什麼？"
            },
            "sent.src.it.dialogue.digital_wifi_connect.t2_npc": {
              "translation": "可以。密碼是 casa2026。"
            },
            "sent.src.it.dialogue.digital_wifi_connect.t2_learner": {
              "translation": "謝謝，我馬上試試。"
            },
            "sent.src.it.dialogue.digital_wifi_connect.t3_npc": {
              "translation": "可以用嗎？"
            },
            "sent.src.it.dialogue.digital_wifi_connect.t3_learner": {
              "translation": "不，連不上。"
            },
            "sent.src.it.dialogue.digital_wifi_connect.t4_npc": {
              "translation": "我了解。請一分鐘後再試一次。"
            },
            "sent.src.it.dialogue.digital_wifi_connect.t4_learner": {
              "translation": "好的，謝謝。"
            }
          }
        },
        "src.it.dialogue.food_bill_payment": {
          "sentences": {
            "sent.src.it.dialogue.food_bill_payment.t1_npc": {
              "translation": "請說。"
            },
            "sent.src.it.dialogue.food_bill_payment.t1_learner": {
              "translation": "請結帳。"
            },
            "sent.src.it.dialogue.food_bill_payment.t2_npc": {
              "translation": "好的。刷卡還是現金？"
            },
            "sent.src.it.dialogue.food_bill_payment.t2_learner": {
              "translation": "刷卡，謝謝。"
            },
            "sent.src.it.dialogue.food_bill_payment.t3_npc": {
              "translation": "您要收據嗎？"
            },
            "sent.src.it.dialogue.food_bill_payment.t3_learner": {
              "translation": "要，謝謝。"
            },
            "sent.src.it.dialogue.food_bill_payment.t4_npc": {
              "translation": "給您。再見。"
