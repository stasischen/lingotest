        "kg.grammar.th.request.help.v1": {
          "knowledge_id": "kg.grammar.th.request.help.v1",
          "title": "請求動詞 ช่วย",
          "description": "用於禮貌請求的動詞",
          "explanation_md": "ช่วย (chuay) 是「幫助」的意思，用於禮貌地請求幫助。例如：ช่วย ฉัน หน่อย (幫我一下)。\n\n- 用於請求\n- 搭配 หน่อย 更禮貌",
