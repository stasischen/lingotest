        "kg.grammar.th.question.krai.v1": {
          "knowledge_id": "kg.grammar.th.question.krai.v1",
          "title": "疑問詞 ใคร",
          "description": "用於詢問人物的疑問詞",
          "explanation_md": "ใคร (krai) 是「誰」的意思，用於詢問人物身份。例如：เขา คือ ใคร？(他是誰？)\n\n- 詢問人物\n- 置於句尾或句中",
          "source_refs": [
