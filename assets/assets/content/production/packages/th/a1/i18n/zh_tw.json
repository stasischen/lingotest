        "kg.grammar.th.adjective.predicative.v1": {
          "knowledge_id": "kg.grammar.th.adjective.predicative.v1",
          "title": "形容詞作表語",
          "description": "形容詞置於名詞後作表語",
          "explanation_md": "泰語的形容詞置於名詞後面，不需要繫詞。例如：นี่ ดี (這好)、อาหาร อร่อย (食物好吃)。\n\n- 置於名詞後\n- 不需要繫詞",
          "source_refs": [
            "content_v2/inventory/learning_library/knowledge/grammar/adjective/kg.grammar.th.adjective.predicative.v1.json"
          ],
          "status": "active",
          "dictionary_refs": [],
          "linkage_display": {}
        },
        "kg.grammar.th.classifier.basic.v1": {
          "knowledge_id": "kg.grammar.th.classifier.basic.v1",
          "title": "量詞基礎",
          "description": "泰語中計數名詞時必須使用的量詞",
          "explanation_md": "泰語在計數名詞時必須使用量詞。例如：一盤菜 (จาน หนึ่ง จาน)、一杯水 (แก้ว หนึ่ง แก้ว)。\n\n- 必須搭配數詞使用\n- 不同名詞用不同量詞",
          "source_refs": [
            "content_v2/inventory/learning_library/knowledge/grammar/classifier/kg.grammar.th.classifier.basic.v1.json"
          ],
          "status": "active",
          "dictionary_refs": [],
          "linkage_display": {}
        },
        "kg.grammar.th.copula.pen_khue.v1": {
          "knowledge_id": "kg.grammar.th.copula.pen_khue.v1",
          "title": "繫詞 เป็น/คือ",
          "description": "用於連接主語和表語的繫詞",
          "explanation_md": "เป็น (pen) 和 คือ (khue) 都是繫詞，但用法不同。เป็น 用於連接主語和名詞或形容詞，คือ 用於定義或解釋。\n\n- เป็น - 連接主語和表語\n- คือ - 用於定義",
          "source_refs": [
            "content_v2/inventory/learning_library/knowledge/grammar/copula/kg.grammar.th.copula.pen_khue.v1.json"
          ],
          "status": "active",
          "dictionary_refs": [
            "th:cop:เป็น",
            "th:cop:คือ"
          ],
          "linkage_display": {}
        },
        "kg.grammar.th.existence.mee.v1": {
          "knowledge_id": "kg.grammar.th.existence.mee.v1",
          "title": "存在動詞 มี",
          "description": "表示擁有或存在的動詞",
          "explanation_md": "มี (mee) 是「有」的意思，表示擁有或存在。例如：我 มี หนังสือ (我有書)、ที่นี่ มี ร้านอาหาร (這裡有餐廳)。\n\n- 表示擁有\n- 表示存在",
          "source_refs": [
            "content_v2/inventory/learning_library/knowledge/grammar/existence/kg.grammar.th.existence.mee.v1.json"
          ],
          "status": "active",
          "dictionary_refs": [
            "th:v:มี"
          ],
          "linkage_display": {}
        },
        "kg.grammar.th.negation.mai.v1": {
          "knowledge_id": "kg.grammar.th.negation.mai.v1",
          "title": "否定詞 ไม่",
          "description": "用於否定句的副詞",
          "explanation_md": "ไม่ (mai) 是泰語中最基本的否定詞，置於動詞或形容詞前面表示否定。例如：ไม่ ไป (不去)、ไม่ ดี (不好)。\n\n- 置於動詞前\n- 置於形容詞前\n- ไม่ 是基本否定",
          "source_refs": [
            "content_v2/inventory/learning_library/knowledge/grammar/negation/kg.grammar.th.negation.mai.v1.json"
          ],
          "status": "active",
          "dictionary_refs": [
            "th:adv:ไม่"
          ],
          "linkage_display": {}
        },
        "kg.grammar.th.particle.krap_ka_polite.v1": {
          "knowledge_id": "kg.grammar.th.particle.krap_ka_polite.v1",
          "title": "禮貌語氣詞用法",
          "description": "ครับ/ค่ะ 在對話中的多種用法",
          "explanation_md": "除了用於句尾外，ครับ/ค่ะ 還可以用於簡短回應，表示同意或禮貌。例如：ครับ (是的，男性)、ค่ะ (是的，女性)。\n\n- 句尾使用\n- 簡短回應\n- 表示同意",
          "source_refs": [
            "content_v2/inventory/learning_library/knowledge/grammar/particle/kg.grammar.th.particle.krap_ka_polite.v1.json"
          ],
          "status": "active",
          "dictionary_refs": [
            "th:part:ครับ",
            "th:part:ค่ะ"
          ],
          "linkage_display": {}
        },
        "kg.grammar.th.particle.polite_particles.v1": {
          "knowledge_id": "kg.grammar.th.particle.polite_particles.v1",
          "title": "禮貌語氣詞 ครับ/ค่ะ",
          "description": "泰語中用於句尾的禮貌語氣詞，男性用 ครับ，女性用 ค่ะ",
          "explanation_md": "在泰語中，為了表達禮貌和尊重，需要在句尾加上語氣詞。男性說話者使用 ครับ (krap)，女性說話者使用 ค่ะ (ka)。這是泰語最基本的禮貌表達方式，在日常對話中幾乎每句話都會使用。\n\n- 男性用 ครับ\n- 女性用 ค่ะ\n- 可以用於句尾或單獨回應",
          "source_refs": [
            "content_v2/inventory/learning_library/knowledge/grammar/particle/kg.grammar.th.particle.polite_particles.v1.json"
          ],
          "status": "active",
          "dictionary_refs": [
            "th:part:ครับ",
            "th:part:ค่ะ"
          ],
          "linkage_display": {}
        },
        "kg.grammar.th.particle.question_maai.v1": {
          "knowledge_id": "kg.grammar.th.particle.question_maai.v1",
          "title": "疑問語氣詞 ไหม/มั้ย",
          "description": "用於句尾構成是非問句的語氣詞",
          "explanation_md": "在泰語中，要在句尾加上 ไหม (mai) 或 มั้ย (mai) 來構成是非問句。兩者意思相同，只是語氣略有不同。這是最基本的疑問句型。\n\n- ไหม - 較正式\n- มั้ย - 較口語\n- 置於句尾",
          "source_refs": [
            "content_v2/inventory/learning_library/knowledge/grammar/particle/kg.grammar.th.particle.question_maai.v1.json"
          ],
          "status": "active",
          "dictionary_refs": [
            "th:part:ไหม",
            "th:part:มั้ย"
          ],
          "linkage_display": {}
        },
        "kg.grammar.th.possessive.khong.v1": {
          "knowledge_id": "kg.grammar.th.possessive.khong.v1",
          "title": "所有格 ของ",
          "description": "用於表示所有關係的介詞",
          "explanation_md": "ของ (khong) 用於連接名詞和代名詞表示所有關係。例如：ของ 我 (我的)、ของ 你 (你的)。\n\n- 連接名詞和代名詞\n- 表示所有關係",
          "source_refs": [
            "content_v2/inventory/learning_library/knowledge/grammar/possessive/kg.grammar.th.possessive.khong.v1.json"
          ],
          "status": "active",
          "dictionary_refs": [
            "th:adp:ของ"
          ],
          "linkage_display": {}
        },
        "kg.grammar.th.pronoun.basic_pronouns.v1": {
          "knowledge_id": "kg.grammar.th.pronoun.basic_pronouns.v1",
          "title": "基本代名詞",
          "description": "泰語中的基本人稱代名詞：ผม、ดิฉัน、คุณ、我們",
          "explanation_md": "泰語的代名詞根據性別和禮貌程度有所不同。ผม (phom) 是男性的「我」，ดิฉัน (dichan) 是女性的「我」，คุณ (khun) 是「你/您」，我們 (rao) 是「我們」。\n\n- ผม - 男性我\n- ดิฉัน - 女性我\n- คุณ - 你/您\n- 我們 - 我們",
          "source_refs": [
            "content_v2/inventory/learning_library/knowledge/grammar/pronoun/kg.grammar.th.pronoun.basic_pronouns.v1.json"
          ],
          "status": "active",
          "dictionary_refs": [
            "th:pron:ผม",
            "th:pron:ดิฉัน",
            "th:pron:คุณ",
            "th:pron:我們"
          ],
          "linkage_display": {}
        },
        "kg.grammar.th.question.arii.v1": {
          "knowledge_id": "kg.grammar.th.question.arii.v1",
          "title": "疑問詞 อะไร",
          "description": "用於詢問事物的疑問詞",
          "explanation_md": "อะไร (arai) 是「什麼」的意思，用於詢問事物或內容。例如：นี่ คือ อะไร？(這是什麼？)\n\n- 詢問事物\n- 置於句尾或句中",
          "source_refs": [
            "content_v2/inventory/learning_library/knowledge/grammar/question/kg.grammar.th.question.arii.v1.json"
