        "src.th.dialogue.convenience_payment_card_cash": {
          "sentences": {
            "sent.src.th.dialogue.convenience_payment_card_cash.t1_npc": {
              "translation": "總共一百二十泰銖。付現金還是刷卡？"
            },
            "sent.src.th.dialogue.convenience_payment_card_cash.t1_learner": {
              "translation": "卡片，謝謝。"
            },
            "sent.src.th.dialogue.convenience_payment_card_cash.t2_npc": {
              "translation": "請在這裡感應卡片。"
            },
            "sent.src.th.dialogue.convenience_payment_card_cash.t2_learner": {
              "translation": "好的。"
            },
            "sent.src.th.dialogue.convenience_payment_card_cash.t3_npc": {
              "translation": "需要袋子嗎？"
            },
            "sent.src.th.dialogue.convenience_payment_card_cash.t3_learner": {
              "translation": "不用袋子。"
            },
            "sent.src.th.dialogue.convenience_payment_card_cash.t4_npc": {
              "translation": "好了，謝謝。"
            },
            "sent.src.th.dialogue.convenience_payment_card_cash.t4_learner": {
              "translation": "謝謝。"
            }
          }
        },
        "src.th.dialogue.core_repair_repeat_slowly": {
          "sentences": {
            "sent.src.th.dialogue.core_repair_repeat_slowly.t1_npc": {
              "translation": "內用還是外帶？"
            },
            "sent.src.th.dialogue.core_repair_repeat_slowly.t1_learner": {
              "translation": "不好意思，可以再說一次嗎？"
            },
            "sent.src.th.dialogue.core_repair_repeat_slowly.t2_npc": {
              "translation": "內用還是外帶？"
            },
            "sent.src.th.dialogue.core_repair_repeat_slowly.t2_learner": {
              "translation": "可以說慢一點嗎？"
            },
            "sent.src.th.dialogue.core_repair_repeat_slowly.t3_npc": {
              "translation": "內用嗎？還是外帶？"
            },
            "sent.src.th.dialogue.core_repair_repeat_slowly.t3_learner": {
              "translation": "外帶，謝謝。"
            },
            "sent.src.th.dialogue.core_repair_repeat_slowly.t4_npc": {
              "translation": "好的，完成了。"
            },
            "sent.src.th.dialogue.core_repair_repeat_slowly.t4_learner": {
              "translation": "謝謝。"
            }
          }
        },
        "src.th.dialogue.daily_meet_friend": {
          "sentences": {
            "sent.src.th.dialogue.daily_meet_friend.t1_npc": {
              "translation": "你來了啊？"
            },
            "sent.src.th.dialogue.daily_meet_friend.t1_learner": {
              "translation": "嗨，很高興見到你。"
            },
            "sent.src.th.dialogue.daily_meet_friend.t2_npc": {
              "translation": "我們要去看電影，對嗎？"
            },
            "sent.src.th.dialogue.daily_meet_friend.t2_learner": {
              "translation": "對，走吧。"
            },
            "sent.src.th.dialogue.daily_meet_friend.t3_npc": {
              "translation": "準備好了嗎？"
            },
            "sent.src.th.dialogue.daily_meet_friend.t3_learner": {
              "translation": "準備好了，走吧。"
            },
            "sent.src.th.dialogue.daily_meet_friend.t4_npc": {
              "translation": "先去買票吧。"
            },
            "sent.src.th.dialogue.daily_meet_friend.t4_learner": {
              "translation": "好，一起去買票吧。"
            }
          }
        },
        "src.th.dialogue.daily_schedule_time": {
          "sentences": {
            "sent.src.th.dialogue.daily_schedule_time.t1_npc": {
              "translation": "明天幾點見好呢？"
            },
            "sent.src.th.dialogue.daily_schedule_time.t1_learner": {
              "translation": "下午三點好嗎？"
            },
            "sent.src.th.dialogue.daily_schedule_time.t2_npc": {
              "translation": "下午三點可以，在車站見喔。"
            },
            "sent.src.th.dialogue.daily_schedule_time.t2_learner": {
              "translation": "可以，在車站見。"
            },
            "sent.src.th.dialogue.daily_schedule_time.t3_npc": {
              "translation": "好，明天下午三點見。"
            },
