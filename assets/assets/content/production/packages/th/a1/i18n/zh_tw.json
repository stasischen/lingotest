        "kg.grammar.th.tense.future_ja.v1": {
          "knowledge_id": "kg.grammar.th.tense.future_ja.v1",
          "title": "未來時態 จะ",
          "description": "用於表示未來動作的副詞",
          "explanation_md": "จะ (cha) 置於動詞前表示未來的動作或意圖。例如：จะ ไป (將要去)、จะ กิน (將要吃)。\n\n- 置於動詞前\n- 表示未來意圖",
