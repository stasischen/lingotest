        "src.de.dialogue.convenience_payment_card_cash": {
          "sentences": {
            "sent.src.de.dialogue.convenience_payment_card_cash.t1_npc": {
              "translation": "您用卡付款還是付現？"
            },
            "sent.src.de.dialogue.convenience_payment_card_cash.t1_learner": {
              "translation": "刷卡，麻煩您。"
            },
            "sent.src.de.dialogue.convenience_payment_card_cash.t2_npc": {
              "translation": "請在這裡插卡。"
            },
            "sent.src.de.dialogue.convenience_payment_card_cash.t2_learner": {
              "translation": "好的，了解。"
            },
            "sent.src.de.dialogue.convenience_payment_card_cash.t3_npc": {
              "translation": "您要收據嗎？"
            },
            "sent.src.de.dialogue.convenience_payment_card_cash.t3_learner": {
              "translation": "不用，謝謝。"
            },
            "sent.src.de.dialogue.convenience_payment_card_cash.t4_npc": {
              "translation": "謝謝您。祝您今天愉快。"
            },
            "sent.src.de.dialogue.convenience_payment_card_cash.t4_learner": {
              "translation": "謝謝，您也是。"
            }
          }
        },
