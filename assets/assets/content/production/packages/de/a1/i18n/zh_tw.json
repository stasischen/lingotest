        "src.de.dialogue.travel_taxi_destination": {
          "sentences": {
            "sent.src.de.dialogue.travel_taxi_destination.t1_npc": {
              "translation": "您好。您想去哪裡？"
            },
            "sent.src.de.dialogue.travel_taxi_destination.t1_learner": {
              "translation": "到阿德勒飯店，謝謝。"
            },
            "sent.src.de.dialogue.travel_taxi_destination.t2_npc": {
              "translation": "到阿德勒飯店，對嗎？"
            },
            "sent.src.de.dialogue.travel_taxi_destination.t2_learner": {
              "translation": "對，沒錯。"
            },
            "sent.src.de.dialogue.travel_taxi_destination.t3_npc": {
              "translation": "好的。大約需要十分鐘。"
            },
            "sent.src.de.dialogue.travel_taxi_destination.t3_learner": {
              "translation": "了解。"
            },
            "sent.src.de.dialogue.travel_taxi_destination.t4_npc": {
              "translation": "我們到了。"
            },
            "sent.src.de.dialogue.travel_taxi_destination.t4_learner": {
              "translation": "非常謝謝。再見。"
            }
