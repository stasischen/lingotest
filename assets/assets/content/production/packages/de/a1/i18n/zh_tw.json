        "src.de.dialogue.travel_ticket_buying": {
          "sentences": {
            "sent.src.de.dialogue.travel_ticket_buying.t1_npc": {
              "translation": "您好，請說？"
            },
            "sent.src.de.dialogue.travel_ticket_buying.t1_learner": {
              "translation": "請給我一張到柏林的票。"
            },
            "sent.src.de.dialogue.travel_ticket_buying.t2_npc": {
              "translation": "一張到柏林的票，對嗎？"
            },
            "sent.src.de.dialogue.travel_ticket_buying.t2_learner": {
              "translation": "是的，沒錯。"
            },
            "sent.src.de.dialogue.travel_ticket_buying.t3_npc": {
              "translation": "一共十二歐元。"
            },
            "sent.src.de.dialogue.travel_ticket_buying.t3_learner": {
              "translation": "刷卡，謝謝。"
            },
            "sent.src.de.dialogue.travel_ticket_buying.t4_npc": {
              "translation": "這是您的車票。三號月台。"
            },
            "sent.src.de.dialogue.travel_ticket_buying.t4_learner": {
              "translation": "謝謝。"
            }
