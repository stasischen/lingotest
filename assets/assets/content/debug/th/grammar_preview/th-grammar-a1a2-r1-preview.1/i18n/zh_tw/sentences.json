{
  "build_id": "th-grammar-a1a2-r1-preview.1",
  "content_version": "r1",
  "entries": {
    "sent.th.phase2.grammar.th-a1-gram-auth-001.01": {
      "note": "用 ครับ 讓感謝更有禮貌。",
      "translation": "謝謝。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-001.02": {
      "note": "用 ค่ะ 讓感謝更有禮貌。",
      "translation": "謝謝。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-002.01": {
      "note": "用 ไหม 問是否有水。",
      "translation": "有水嗎？"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-002.02": {
      "note": "服務情境中用 ไหม 提供選項。",
      "translation": "要咖啡嗎？"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-002.03": {
      "note": "มั้ย 是較口語的寫法，這裡用來辨認常見口語形式。",
      "translation": "要水嗎？"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-003.01": {
      "note": "ไม่ 放在形容詞前面。",
      "translation": "這個不貴。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-003.02": {
      "note": "ไม่ 放在動詞前面。",
      "translation": "我不吃辣。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-004.01": {
      "note": "มี 表示某處有東西或可用。",
      "translation": "這裡有空房。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-004.02": {
      "note": "มี 也可以表示擁有。",
      "translation": "我有卡。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-005.01": {
      "note": "用 ที่ไหน 問地點。",
      "translation": "廁所在哪裡？"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-005.02": {
      "note": "用 ที่ไหน 問某個地方的位置。",
      "translation": "車站在哪裡？"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-006.01": {
      "note": "用 อะไร 問對方想要的東西。",
      "translation": "要什麼？"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-006.02": {
      "note": "用 อะไร 問物品或內容。",
      "translation": "這個是什麼？"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-007.01": {
      "note": "用 ใคร 問人的身分。",
      "translation": "這個人是誰？"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-007.02": {
      "note": "用 ของใคร 問擁有者。",
      "translation": "這張卡是誰的？"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-008.01": {
      "note": "用 เท่าไหร่ 問價格。",
      "translation": "這個多少錢？"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-008.02": {
      "note": "用 เท่าไหร่ 問總額。",
      "translation": "總共多少？"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-009.01": {
      "note": "用 ของ 連接物品和擁有者。",
      "translation": "這是我的包。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-009.02": {
      "note": "ของคุณ 表示「您的」。",
      "translation": "這張卡是您的。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-010.01": {
      "note": "คน 是數人的分類詞。",
      "translation": "兩位大人。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-010.02": {
      "note": "แก้ว 可用來數杯裝飲料。",
      "translation": "兩杯水。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-010.03": {
      "note": "ใบ 可用來數卡片、票券或紙張等扁平物。",
      "translation": "一張卡。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-010.04": {
      "note": "จาน 可用來數盤裝食物。",
      "translation": "一盤飯。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-011.01": {
      "note": "形容詞直接描述主語。",
      "translation": "這個很貴。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-011.02": {
      "note": "泰文簡單描述中不需要英文式 be。",
      "translation": "這道菜很好。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-012.01": {
      "note": "เป็น 用來說身份或類別。",
      "translation": "我是學生。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-012.02": {
      "note": "คือ 用來指出或說明。",
      "translation": "這是旅館。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-013.01": {
      "note": "這是詢問對方能不能幫忙的請求。",
      "translation": "可以請您說慢一點嗎？"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-013.02": {
      "note": "這是柔和、直接的服務請求。",
      "translation": "請幫我叫計程車。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-014.01": {
      "note": "這句使用男性說話者常用的自稱。",
      "translation": "我叫 Dan。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-014.02": {
      "note": "這句使用安全的對方稱呼。",
      "translation": "您住在這裡嗎？"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-014.03": {
      "note": "這句同時有第三人稱和說話者自稱。",
      "translation": "他是我的朋友。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-014.04": {
      "note": "這句把說話者和對方放在同一組。",
      "translation": "我們可以一起去嗎？"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-014.05": {
      "note": "這是比較正式的女性說話者自稱。",
      "translation": "我叫 May。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-015.01": {
      "note": "時間詞標出今天，不需要改動詞。",
      "translation": "今天我在曼谷。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-015.02": {
      "note": "時間詞標出明天，不需要改動詞。",
      "translation": "明天我去清邁。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-015.03": {
      "note": "時間詞標出昨天，不需要改動詞。",
      "translation": "昨天下雨了。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-015.04": {
      "note": "時間詞標出現在的狀態。",
      "translation": "現在店開著。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-016.01": {
      "note": "主語、動詞、受詞都明確出現。",
      "translation": "我吃飯。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-016.02": {
      "note": "問句也可以保留主語、動詞、受詞。",
      "translation": "您看菜單嗎？"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-017.01": {
      "note": "名詞在前，形容詞在後。",
      "translation": "有小房間嗎？"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-017.02": {
      "note": "名詞在前，形容詞在後。",
      "translation": "我要熱咖啡。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-018.01": {
      "note": "程度詞放在描述後面。",
      "translation": "這間旅館很方便。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-018.02": {
      "note": "มาก 加強喜歡的程度。",
      "translation": "我很喜歡這裡。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-019.01": {
      "note": "ไม่ใช่ 後面接名詞片語。",
      "translation": "不是這間旅館。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-019.02": {
      "note": "ไม่ใช่ 用來更正身分或名稱。",
      "translation": "不是我的名字。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-019.03": {
      "note": "ไม่ใช่ 可以用來更正物品類別。",
      "translation": "這個不是咖啡。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-020.01": {
      "note": "確認顧客姓名時使用。",
      "translation": "您的名字是林，對嗎？"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-020.02": {
      "note": "確認房間是否正確時使用。",
      "translation": "是這個房間，對嗎？"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-021.01": {
      "note": "直接表達簡單飲食需求。",
      "translation": "我想吃飯。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-021.02": {
      "note": "直接表達想休息。",
      "translation": "我想休息。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-022.01": {
      "note": "เอา 可用在點餐或選東西。",
      "translation": "我要一杯水。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-022.02": {
      "note": "เอาอันนี้ 是常見選物句。",
      "translation": "我要這個。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-023.01": {
      "note": "ชอบ 後面接名詞。",
      "translation": "我喜歡咖啡。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-023.02": {
      "note": "ชอบ 後面也可以接動作。",
      "translation": "我喜歡在公園散步。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-024.01": {
      "note": "ได้ไหม 放在動作後面，用來問可不可以。",
      "translation": "可以坐這裡嗎？"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-024.02": {
      "note": "ได้ 表示這件事可行。",
      "translation": "可以用卡付款。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-025.01": {
      "note": "อันนี้ 指這個東西。",
      "translation": "我要這個。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-025.02": {
      "note": "อันนั้น 指那個東西。",
      "translation": "那個貴嗎？"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-026.01": {
      "note": "จะ 放在動詞前面，標出接下來的計畫。",
      "translation": "明天我要去清邁。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-026.02": {
      "note": "จะ + 動詞可以說簡單安排。",
      "translation": "我要在這裡吃飯。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-027.01": {
      "note": "แล้ว 放在動作後面，表示完成。",
      "translation": "已經付了。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-027.02": {
      "note": "แล้ว 表示事情已經做了。",
      "translation": "已經吃飯了。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-028.01": {
      "note": "และ 在這句連接兩個項目。",
      "translation": "這份菜單有咖啡和茶。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-028.02": {
      "note": "กับ 在這句表示和某人一起。",
      "translation": "我和朋友一起去。"
    },
    "sent.th.phase2.grammar.th-a1-gram-auth-028.03": {
      "note": "ด้วย 在這句表示也要。",
      "translation": "也請給我一個袋子。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-001.01": {
      "note": "กว่า 放在形容詞後面。",
      "translation": "這間房比那間房便宜。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-001.02": {
      "note": "กว่า 標出比較關係。",
      "translation": "火車比公車快。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-001.03": {
      "note": "比較對象很清楚時，กว่า 後面的 B 可以省略。",
      "translation": "這個比較方便嗎？"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-002.01": {
      "note": "ดีกว่า 放在建議的動作後面。",
      "translation": "明天去比較好。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-002.02": {
      "note": "ดีกว่า 表示這個選擇更合適。",
      "translation": "選這個比較好。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-003.01": {
      "note": "จะ 標出接下來的安排。",
      "translation": "明天我會在十點退房。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-003.02": {
      "note": "จะ 放在動詞前面說計畫。",
      "translation": "我會回來拿包包。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-004.01": {
      "note": "แล้ว 回報事情已完成。",
      "translation": "房間已經訂好了。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-004.02": {
      "note": "แล้ว 放在動作後面說完成。",
      "translation": "已經寄出 email 了。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-005.01": {
      "note": "กำลัง 表示動作正在進行。",
      "translation": "我正在等計程車。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-005.02": {
      "note": "กำลัง 放在動詞前面。",
      "translation": "車正在去機場。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-006.01": {
      "note": "ก่อน 標出先做的步驟，แล้ว 接下一步。",
      "translation": "請先填表，然後等叫名字。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-006.02": {
      "note": "หลังจากนั้น 和 ต่อไป 都能把流程往下接。",
      "translation": "之後到二號櫃台，接下來等收據。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-007.01": {
      "note": "เพราะ 說原因，เลย 接自然發生的結果。",
      "translation": "因為下雨，車來得比較晚。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-007.02": {
      "note": "ดังนั้น 用來整理出後面的結果。",
      "translation": "房間滿了，所以還要再等一下。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-008.01": {
      "note": "ได้ 放在動作後面，表示這件事可行。",
      "translation": "可以用卡付款。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-008.02": {
      "note": "ขอ + 動詞 + ได้ไหม 是禮貌地問可不可以。",
      "translation": "可以寄放行李嗎？"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-009.01": {
      "note": "ต้อง 放在動詞前面表示必須。",
      "translation": "必須在櫃台出示護照。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-009.02": {
      "note": "ห้าม 表示禁止，ไม่ต้อง 表示不需要。",
      "translation": "房間內禁止吸菸，而且不用多付錢。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-010.01": {
      "note": "ถ้า 標出前面的條件。",
      "translation": "如果下雨，我會打電話給你。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-010.02": {
      "note": "ถ้า 可以接服務情境裡的替代方案。",
      "translation": "如果房間滿了，我們可以去別的地方。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-011.01": {
      "note": "จาก、ไป、ถึง 一起說明路線。",
      "translation": "車從飯店出發去機場，下午到。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-011.02": {
      "note": "ใน 說在裡面，ลงที่ 說在哪裡下車。",
      "translation": "店在百貨裡，在下一站下車。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-012.01": {
      "note": "กว่า 放在數量後面，表示大約超過。",
      "translation": "有十幾個人在等。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-012.02": {
      "note": "กว่า 也可以放在時間單位後面。",
      "translation": "坐車兩個多小時。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-013.01": {
      "note": "เพราะ 接原因。",
      "translation": "我因為塞車來晚了。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-013.02": {
      "note": "เพราะว่า 也可以接原因。",
      "translation": "我們換店，因為原本那家關了。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-014.01": {
      "note": "ก็เลย 接在結果前面。",
      "translation": "因為下雨，所以在旅館等。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-014.02": {
      "note": "ก็เลย 連接原因和自然結果。",
      "translation": "公車太慢，所以坐計程車。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-014.03": {
      "note": "ก็เลย 不是所有 เลย 的用法。",
      "translation": "咖啡賣完了，所以點茶。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-015.01": {
      "note": "先給正面評價，再補上限制。",
      "translation": "這個房間很好，但是貴。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-015.02": {
      "note": "用轉折說明計畫受阻。",
      "translation": "我想去，但是下雨了。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-016.01": {
      "note": "提供飲料選項。",
      "translation": "要咖啡還是茶？"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-016.02": {
      "note": "提供座位選項。",
      "translation": "坐裡面還是外面？"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-017.01": {
      "note": "เคย 放在動詞前面問經驗。",
      "translation": "你去過清邁嗎？"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-017.02": {
      "note": "เคย 可以說以前做過某件事。",
      "translation": "我以前在這裡吃過泰國菜。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-018.01": {
      "note": "เพิ่ง 表示事情剛發生不久。",
      "translation": "我剛到飯店。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-018.02": {
      "note": "เพิ่ง 放在動詞前面說剛剛才做。",
      "translation": "我剛把表格送出。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-019.01": {
      "note": "กำลังจะ 表示很快就要做。",
      "translation": "我正要離開飯店。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-019.02": {
      "note": "กำลังจะ 可以說快要發生的動作。",
      "translation": "車快要到車站了。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-020.01": {
      "note": "ยังไม่ 表示動作還沒完成。",
      "translation": "我還沒有付款。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-020.02": {
      "note": "ยังไม่ 也可以放在形容詞前說狀態還不成立。",
      "translation": "房間還沒準備好。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-021.01": {
      "note": "ควร 放在動詞前面提出建議。",
      "translation": "你應該先訂位。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-021.02": {
      "note": "ควรจะ 也可以放在動詞前面。",
      "translation": "我們應該早一點去。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-022.01": {
      "note": "เอา 和 ไป 一起表示把東西拿到別處。",
      "translation": "我會把行李拿去車上。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-022.02": {
      "note": "เอา 和 มา 一起表示把東西拿到這邊。",
      "translation": "請把收據拿來給我。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-023.01": {
      "note": "ไป + 地點 + มา 表示去了又回來。",
      "translation": "昨天我去了市場回來。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-023.02": {
      "note": "มา 放在地點後面，表示行程已經回來。",
      "translation": "我們去了博物館回來。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-024.01": {
      "note": "ที่ 接在名詞後面，引出描述那家店的小句。",
      "translation": "靠近車站的店開到晚上九點。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-024.02": {
      "note": "ที่จองไว้ 用來說明是哪一間房。",
      "translation": "訂好的房間在五樓。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-025.01": {
      "note": "บ่อยๆ 表示常常。",
      "translation": "我常來這家店。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-025.02": {
      "note": "ทุกวัน 表示每天，บางครั้ง 表示有時候。",
      "translation": "我每天喝咖啡，但有時候喝茶。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-026.01": {
      "note": "ที่สุด 放在形容詞後面。",
      "translation": "這家店最便宜。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-026.02": {
      "note": "ที่สุด 可以用來說最接近。",
      "translation": "這個車站最近。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-027.01": {
      "note": "เมื่อวาน 標時間，แล้ว 接後續，รู้สึก 說感覺。",
      "translation": "昨天我去了市場回來，然後覺得累。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-027.02": {
      "note": "รู้สึก 後面接感覺。",
      "translation": "昨天下雨，然後我覺得冷。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-028.01": {
      "note": "ปวดหัว 只是在描述不舒服。",
      "translation": "今天我有一點頭痛。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-028.02": {
      "note": "ปวดท้อง 和 ไม่สบาย 都是描述狀態，不是診斷。",
      "translation": "我肚子痛，而且不舒服。"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-029.01": {
      "note": "เมื่อไหร่ 問時間。",
      "translation": "車什麼時候出發？"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-029.02": {
      "note": "ทำไม 問原因。",
      "translation": "為什麼這家店今天關門？"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-029.03": {
      "note": "ยังไง 是口語的怎麼。",
      "translation": "要怎麼去車站？"
    },
    "sent.th.phase2.grammar.th-a2-gram-auth-029.04": {
      "note": "อย่างไร 比 ยังไง 更正式。",
      "translation": "這張表格要如何填寫？"
    }
  },
