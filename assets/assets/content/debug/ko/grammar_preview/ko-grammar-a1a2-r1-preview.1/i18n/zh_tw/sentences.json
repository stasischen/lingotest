{
  "content_version": "r1",
  "entries": {
    "sent.ko.phase2.grammar.ko-a1-family-articles.01": {
      "note": "",
      "translation": "這一位是我們的老師。"
    },
    "sent.ko.phase2.grammar.ko-a1-family-articles.02": {
      "note": "",
      "translation": "那本書是我的書。"
    },
    "sent.ko.phase2.grammar.ko-a1-family-counter_quantity.01": {
      "note": "",
      "translation": "請給我兩個蘋果和三個橘子。"
    },
    "sent.ko.phase2.grammar.ko-a1-family-counter_quantity.02": {
      "note": "",
      "translation": "請給我兩張電影票。"
    },
    "sent.ko.phase2.grammar.ko-a1-family-counter_quantity.03": {
      "note": "",
      "translation": "請給我兩杯咖啡。"
    },
    "sent.ko.phase2.grammar.ko-a1-family-demonstrative.01": {
      "note": "",
      "translation": "正是這個。"
    },
    "sent.ko.phase2.grammar.ko-a1-family-demonstrative.02": {
      "note": "",
      "translation": "別摸那個。"
    },
    "sent.ko.phase2.grammar.ko-a1-family-like_preference.01": {
      "note": "",
      "translation": "我喜歡蘋果。"
    },
    "sent.ko.phase2.grammar.ko-a1-family-like_preference.02": {
      "note": "",
      "translation": "小狗喜歡散步。"
    },
    "sent.ko.phase2.grammar.ko-a1-family-polite_request.01": {
      "note": "",
      "translation": "這個包包太重了，請幫我拿一下。"
    },
    "sent.ko.phase2.grammar.ko-a1-family-polite_request.02": {
      "note": "",
      "translation": "請幫我開一下窗戶。"
    },
    "sent.ko.phase2.grammar.ko-a1-family-possessive.01": {
      "note": "",
      "translation": "那本書是我的書。"
    },
    "sent.ko.phase2.grammar.ko-a1-family-possessive.02": {
      "note": "",
      "translation": "這枝鉛筆是我的（東西）。"
    },
    "sent.ko.phase2.grammar.ko-a1-family-question_how.01": {
      "note": "",
      "translation": "關於這本書你覺得怎麼樣？"
    },
    "sent.ko.phase2.grammar.ko-a1-family-question_how_much.01": {
      "note": "",
      "translation": "這個包包多少錢？"
    },
    "sent.ko.phase2.grammar.ko-a1-family-question_what.01": {
      "note": "",
      "translation": "上週看的電影名稱是什麼？"
    },
    "sent.ko.phase2.grammar.ko-a1-family-question_what.02": {
      "note": "",
      "translation": "這家餐廳最好吃的食物是什麼？"
    },
    "sent.ko.phase2.grammar.ko-a1-family-question_when.01": {
      "note": "",
      "translation": "什麼時候來韓國的？"
    },
    "sent.ko.phase2.grammar.ko-a1-family-question_when.02": {
      "note": "",
      "translation": "正在等朋友，他什麼時候來？"
    },
    "sent.ko.phase2.grammar.ko-a1-family-question_where.01": {
      "note": "",
      "translation": "這裡是哪裡？"
    },
    "sent.ko.phase2.grammar.ko-a1-family-question_where.02": {
      "note": "",
      "translation": "洗手間在哪裡？"
    },
    "sent.ko.phase2.grammar.ko-a1-family-question_who.01": {
      "note": "",
      "translation": "剛才打電話來的人是誰？"
    },
    "sent.ko.phase2.grammar.ko-a1-family-question_who.02": {
      "note": "",
      "translation": "剛剛進來的那個人是誰？"
    },
    "sent.ko.phase2.grammar.ko-a1-family-softener.01": {
      "note": "",
      "translation": "這個包包太重了，請幫我拿一下。"
    },
    "sent.ko.phase2.grammar.ko-a1-family-softener.02": {
      "note": "",
      "translation": "請幫我開一下窗戶。"
    },
    "sent.ko.phase2.grammar.ko-a1-family-subject_pronoun.01": {
      "note": "",
      "translation": "我是學生。"
    },
    "sent.ko.phase2.grammar.ko-a1-family-subject_pronoun.02": {
      "note": "",
      "translation": "我的興趣是游泳。"
    },
    "sent.ko.phase2.grammar.ko-a1-family-which_question.01": {
      "note": "",
      "translation": "你是哪國人？"
    },
    "sent.ko.phase2.grammar.ko-a1-family-which_question.02": {
      "note": "",
      "translation": "今天看哪部電影呢？"
    },
    "sent.ko.phase2.grammar.ko-a1-gram-v2-001.01": {
      "note": "這裡用 이 標示主語。",
      "translation": "這一位是我們的老師。"
    },
    "sent.ko.phase2.grammar.ko-a1-gram-v2-001.02": {
      "note": "這裡用 가 標示主語。",
      "translation": "火車來了。"
    },
    "sent.ko.phase2.grammar.ko-a1-gram-v2-002.01": {
      "note": "這裡用 는 標示主題。",
      "translation": "Min-ji 是廚師。"
    },
    "sent.ko.phase2.grammar.ko-a1-gram-v2-002.02": {
      "note": "這裡用 는 標示主題。",
      "translation": "香蕉很甜。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-001.01": {
      "note": "",
      "translation": "我會唱韓國歌。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-001.02": {
      "note": "",
      "translation": "明天能見面嗎？"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-002.01": {
      "note": "",
      "translation": "我彈鋼琴，但彈得不太好（沒辦法彈好）。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-002.02": {
      "note": "",
      "translation": "現在沒辦法去購物。我太忙了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-007.01": {
      "note": "",
      "translation": "立刻出發。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-007.02": {
      "note": "",
      "translation": "立刻開始。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-015.01": {
      "note": "",
      "translation": "再去。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-015.02": {
      "note": "",
      "translation": "再寫。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-029.01": {
      "note": "",
      "translation": "請問這附近有銀行嗎？"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-029.02": {
      "note": "",
      "translation": "請問你有看到我的手機嗎？"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-030.01": {
      "note": "",
      "translation": "現在出發吧。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-030.02": {
      "note": "",
      "translation": "現在停止吧。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-038.01": {
      "note": "",
      "translation": "這個蛋糕真的很好吃。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-038.02": {
      "note": "",
      "translation": "今天天氣真熱啊。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-056.01": {
      "note": "",
      "translation": "賢宇果然運動神經很好呢。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-056.02": {
      "note": "",
      "translation": "這家的食物果然不負眾望。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-058.01": {
      "note": "",
      "source_i18n_id": "ex.ko.s.000034",
      "translation": "這一位是我們的老師。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-058.02": {
      "note": "",
      "source_i18n_id": "ex.ko.s.000044",
      "translation": "Min-ji 是廚師。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-059.01": {
      "note": "",
      "translation": "我叔叔是日本人。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-059.02": {
      "note": "",
      "translation": "這個玩偶是我弟弟的禮物。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-061.01": {
      "note": "",
      "translation": "想去山上。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-061.02": {
      "note": "",
      "translation": "我想喝涼水。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-062.01": {
      "note": "",
      "translation": "我弟弟想買新電腦。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-062.02": {
      "note": "",
      "translation": "我覺得我們的小狗好像想散步。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-066.01": {
      "note": "",
      "translation": "大學畢業之後，我打算去上班（就職）。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-066.02": {
      "note": "",
      "translation": "吃完早餐之後，請吃點水果。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-067.01": {
      "note": "",
      "translation": "做完作業後，我和朋友見面了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-067.02": {
      "note": "",
      "translation": "吃完午飯後，喝了咖啡。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-068.01": {
      "note": "",
      "translation": "學韓文已經一年了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-068.02": {
      "note": "",
      "translation": "在這家公司工作已經五年了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-069.01": {
      "note": "",
      "translation": "一回到家就馬上睡著了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-069.02": {
      "note": "",
      "translation": "一接到電話就出門了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-070.01": {
      "note": "",
      "translation": "天氣冷，請穿暖一點。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-070.02": {
      "note": "",
      "translation": "我現在要去市場，要一起去嗎？"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-071.01": {
      "note": "",
      "translation": "正在下雨，你有傘嗎？"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-071.02": {
      "note": "",
      "translation": "肚子餓了，要不要去吃飯？"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-072.01": {
      "note": "",
      "translation": "課程9點開始，1點結束喔。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-072.02": {
      "note": "",
      "translation": "這辣炒年糕真的很好吃。你也吃吃看（你也吃）。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-073.01": {
      "note": "",
      "translation": "吃飯之前洗手。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-073.02": {
      "note": "",
      "translation": "做飯之前先買菜。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-074.01": {
      "note": "",
      "translation": "這個包包太重了，請幫我拿一下。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-074.02": {
      "note": "",
      "translation": "請幫我開一下窗戶。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-075.01": {
      "note": "",
      "translation": "因為下雨所以撐了傘。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-075.02": {
      "note": "",
      "translation": "因為塞車所以遲到了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-076.01": {
      "note": "",
      "translation": "因為天氣很冷，所以穿了大衣。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-076.02": {
      "note": "",
      "translation": "因為肚子餓，所以去餐廳。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-077.01": {
      "note": "",
      "translation": "因為是學生，所以必須要多學習。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-077.02": {
      "note": "",
      "translation": "因為是學生的緣故，無法經常出門旅行。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-078.01": {
      "note": "",
      "translation": "因為肚子餓，所以早點吃飯吧。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-078.02": {
      "note": "",
      "translation": "因為下雨，請帶傘出門。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-079.01": {
      "note": "",
      "translation": "午餐我要選泡菜鍋。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-079.02": {
      "note": "",
      "translation": "我要（選）冰美式咖啡。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-080.01": {
      "note": "",
      "translation": "週末時看電影或看書。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-080.02": {
      "note": "",
      "translation": "早上吃麵包或喝牛奶。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-081.01": {
      "note": "",
      "translation": "這支手機雖然好，但是太貴了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-081.02": {
      "note": "",
      "translation": "泡菜雖然辣，但是很好吃。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-083.01": {
      "note": "",
      "translation": "如果頭很痛的話，請吃點藥。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-083.02": {
      "note": "",
      "translation": "如果天氣冷的話，請穿上大衣。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-084.01": {
      "note": "",
      "translation": "昨天因為吃太多了，所以肚子痛。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-084.02": {
      "note": "",
      "translation": "因為熬夜了，現在非常累。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-085.01": {
      "note": "",
      "source_i18n_id": "ex.ko.s.001020",
      "translation": "肚子好餓，煮個泡麵之類的來吃吧。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-085.02": {
      "note": "",
      "source_i18n_id": "ex.ko.s.001465",
      "translation": "一直走到鞋子都磨損了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-086.01": {
      "note": "",
      "translation": "我做完功課後玩了遊戲。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-086.02": {
      "note": "",
      "translation": "洗過手後吃飯。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-087.01": {
      "note": "",
      "translation": "韓文雖然難，但很有趣。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-087.02": {
      "note": "",
      "translation": "工作雖然辛苦，但很有成就感。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-088.01": {
      "note": "",
      "translation": "持續練習的話，會變得越來越好。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-088.02": {
      "note": "",
      "translation": "住久了自然會產生感情。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-089.01": {
      "note": "",
      "translation": "你也知道，保固期已經結束了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-089.02": {
      "note": "",
      "translation": "如你所見，我現在非常忙。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-091.01": {
      "note": "",
      "translation": "花錢就像流水一樣。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-091.02": {
      "note": "",
      "translation": "歲月就像流雲一般消逝。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-092.01": {
      "note": "",
      "translation": "哇，今天天氣真的很好耶！"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-092.02": {
      "note": "",
      "translation": "你韓文歌唱得真好耶。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-093.01": {
      "note": "",
      "translation": "可以去，但請不要遲到。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-093.02": {
      "note": "",
      "translation": "可以吃，但請適量。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-094.01": {
      "note": "",
      "translation": "讀書讀到深夜。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-094.02": {
      "note": "",
      "translation": "請大聲點說，好讓大家都能聽見。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-095.01": {
      "note": "",
      "translation": "孩子見到媽媽感到很開心。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-095.02": {
      "note": "",
      "translation": "弟弟害怕打針。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-097.01": {
      "note": "",
      "translation": "擔心會下雨所以帶了雨傘。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-097.02": {
      "note": "",
      "translation": "擔心會考不及格，所以很擔心。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-099.01": {
      "note": "",
      "translation": "唯恐吵醒寶寶，小心翼翼地走出了房間。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-099.02": {
      "note": "",
      "translation": "唯恐錯過公車，急忙跑向了站牌。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-100.01": {
      "note": "",
      "translation": "您應該很忙，卻還抽空過來，非常感謝。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-100.02": {
      "note": "",
      "translation": "您應該很餓了，請快點吃吧。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-101.01": {
      "note": "",
      "translation": "我來做飯，所以請幫忙洗碗。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-101.02": {
      "note": "",
      "translation": "明天大概會下雨，所以就在家休息吧。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-102.01": {
      "note": "",
      "translation": "地下室雖然在夏天很涼爽，反面在冬天卻非常寒冷。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-102.02": {
      "note": "",
      "translation": "這家餐廳雖然好吃，但另一方面價格有點貴。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-103.01": {
      "note": "",
      "translation": "開著燈就睡著了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-103.02": {
      "note": "",
      "translation": "穿著衣服就進到水裡了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-104.01": {
      "note": "",
      "translation": "按照老師吩咐的做了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-104.02": {
      "note": "",
      "translation": "一到達請立刻給我打電話。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-105.01": {
      "note": "",
      "translation": "如果明天中了彩券的話，你想做什麼？"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-105.02": {
      "note": "",
      "translation": "如果我能再次出生的話，我想成為一名藝術家。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-106.01": {
      "note": "",
      "translation": "我去超市的時候，順便買了牛奶。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-106.02": {
      "note": "",
      "translation": "我去學校的時候，順便見了朋友。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-107.01": {
      "note": "",
      "translation": "別說是飯了，連水都沒喝。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-107.02": {
      "note": "",
      "translation": "別說是唸書了，連書都沒打開。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-109.01": {
      "note": "",
      "translation": "哇～今天天氣真冷。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-109.02": {
      "note": "",
      "translation": "哇，玫瑰花真漂亮。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-111.01": {
      "note": "",
      "translation": "我弟弟/妹妹（或室友）還沒有來耶。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-111.02": {
      "note": "",
      "translation": "因為冷氣的關係，這裡有點冷耶。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-112.01": {
      "note": "",
      "translation": "民秀先生是老師。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-112.02": {
      "note": "",
      "translation": "那個是包包。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-115.01": {
      "note": "",
      "translation": "雖然很努力讀書，卻沒考上試。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-115.02": {
      "note": "",
      "translation": "雖然下著雨，他卻沒撐傘在走路。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-116.01": {
      "note": "",
      "translation": "課一結束學生們就立刻走出教室了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-116.02": {
      "note": "",
      "translation": "薪水一領到就全部花光了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-117.01": {
      "note": "",
      "translation": "比起做作業，我更想玩遊戲。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-117.02": {
      "note": "",
      "translation": "比起去山上，我更想去海邊。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-119.01": {
      "note": "",
      "source_i18n_id": "ex.ko.s.000525",
      "translation": "要去首爾的話，必須搭火車。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-119.02": {
      "note": "",
      "source_i18n_id": "ex.ko.s.001672",
      "translation": "要去首爾站的話，最近的路在哪裡？"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-120.01": {
      "note": "",
      "translation": "今後我會更加努力學習的。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-120.02": {
      "note": "",
      "translation": "今天工作很多，你應該很累吧。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-121.01": {
      "note": "",
      "translation": "為了寄禮物給在故鄉的父母，正要去郵局。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-121.02": {
      "note": "",
      "translation": "為了不遲到，所以早上很早就起床了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-123.01": {
      "note": "",
      "translation": "學生在學校必須努力讀書。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-123.02": {
      "note": "",
      "translation": "為了健康，必須每天運動。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-126.01": {
      "note": "",
      "source_i18n_id": "ex.ko.s.000862",
      "translation": "現在正在開會中，有點難講電話耶。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-126.02": {
      "note": "",
      "source_i18n_id": "ex.ko.s.001669",
      "translation": "我最討厭做功課。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-127.01": {
      "note": "",
      "translation": "我沒試過做太極道。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-127.02": {
      "note": "",
      "translation": "我沒試過吃烤肉。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-128.01": {
      "note": "",
      "source_i18n_id": "ex.ko.s.000357",
      "translation": "昨天讀過的書真的很有趣。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-128.02": {
      "note": "",
      "source_i18n_id": "ex.ko.s.000396",
      "translation": "剛才吃的三明治非常美味。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-129.01": {
      "note": "",
      "translation": "以前住過韓國。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-129.02": {
      "note": "",
      "translation": "當學生時曾很努力讀書。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-131.01": {
      "note": "",
      "source_i18n_id": "ex.ko.s.002036",
      "translation": "努力不會背叛人，然而運氣也很重要。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-131.02": {
      "note": "",
      "source_i18n_id": "ex.ko.s.002038",
      "translation": "都市很華麗，然而生活費很高。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-132.01": {
      "note": "",
      "translation": "請在這裡寫下姓名和電話號碼。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-132.02": {
      "note": "",
      "translation": "路況複雜，請小心開車。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-133.01": {
      "note": "",
      "source_i18n_id": "ex.ko.s.000541",
      "translation": "火車好像已經開走了。怎麼辦呢？"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-133.02": {
      "note": "",
      "source_i18n_id": "ex.ko.s.002070",
      "translation": "如果是小孩還好說，大人不應該犯這種錯誤。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-134.01": {
      "note": "",
      "translation": "回家。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-134.02": {
      "note": "",
      "translation": "吃飯。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-135.01": {
      "note": "",
      "translation": "現在正在看電影。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-135.02": {
      "note": "",
      "translation": "正在等朋友。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-136.01": {
      "note": "",
      "translation": "別擔心。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-136.02": {
      "note": "",
      "translation": "別哭。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-137.01": {
      "note": "",
      "translation": "我們別互相吵架吧。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-137.02": {
      "note": "",
      "translation": "我們別浪費時間吧。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-138.01": {
      "note": "",
      "translation": "請不要在這裡拍照。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-138.02": {
      "note": "",
      "translation": "上課時間請不要吵鬧。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-139.01": {
      "note": "",
      "translation": "這週末約好要和朋友們去登山。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-139.02": {
      "note": "",
      "translation": "決定從明天開始不抽菸了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-140.01": {
      "note": "",
      "translation": "稍後會再來。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-140.02": {
      "note": "",
      "translation": "明天會打電話。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-142.01": {
      "note": "",
      "translation": "肚子餓了，我們去吃午飯吧。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-142.02": {
      "note": "",
      "translation": "週末去電影院看電影吧。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-143.01": {
      "note": "",
      "translation": "太晚了，今天我們別出去了吧。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-143.02": {
      "note": "",
      "translation": "為了我們的健康，今天別喝酒了吧。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-144.01": {
      "note": "",
      "translation": "從今天起，大家一起努力運動吧。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-144.02": {
      "note": "",
      "translation": "我們明天上午10點見面吧。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-151.01": {
      "note": "",
      "translation": "請把家裡打掃乾淨。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-151.02": {
      "note": "",
      "translation": "請穿暖和一點。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-153.01": {
      "note": "",
      "source_i18n_id": "ex.ko.s.001687",
      "translation": "請問這附近有銀行嗎？"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-153.02": {
      "note": "",
      "source_i18n_id": "ex.ko.s.001692",
      "translation": "請問上次提到的那本書讀完了嗎？"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-154.01": {
      "note": "",
      "translation": "天氣突然變冷了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-154.02": {
      "note": "",
      "translation": "房間變得非常乾淨。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-155.01": {
      "note": "",
      "translation": "花開著。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-155.02": {
      "note": "",
      "translation": "門開著。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-156.01": {
      "note": "",
      "source_i18n_id": "ex.ko.s.000597",
      "translation": "要不要一起吃午餐呢？"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-156.02": {
      "note": "",
      "source_i18n_id": "ex.ko.s.000598",
      "translation": "要看哪部電影呢？"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-159.01": {
      "note": "",
      "translation": "我試過吃泡菜。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-159.02": {
      "note": "",
      "translation": "我試過往南大門市場去。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-160.01": {
      "note": "",
      "translation": "儘管天氣非常冷，還是聚集了很多人。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-160.02": {
      "note": "",
      "translation": "儘管行程繁忙，還是感謝您出席會議。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-161.01": {
      "note": "",
      "translation": "藉由多看書，可以累積多樣的知識。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-161.02": {
      "note": "",
      "translation": "透過規律運動，可以維持健康。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-162.01": {
      "note": "",
      "translation": "除非是非常急的事，否則平常不搭計程車。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-162.02": {
      "note": "",
      "translation": "如果是免費的還好，要付錢的話就不想去了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-163.01": {
      "note": "",
      "translation": "吃飯的時候請保持安靜。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-163.02": {
      "note": "",
      "translation": "睡覺的時候聽音樂。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-164.01": {
      "note": "",
      "translation": "一邊聽音樂一邊學習。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-164.02": {
      "note": "",
      "translation": "一邊吃飯一邊看報紙。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-165.01": {
      "note": "",
      "translation": "天氣變冷了耶。我看我得再多穿點衣服。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-165.02": {
      "note": "",
      "translation": "肚子太餓了。我看我得快點吃飯。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-166.01": {
      "note": "",
      "translation": "我會早點來的。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-166.02": {
      "note": "",
      "translation": "我會幫你的。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-167.01": {
      "note": "",
      "translation": "希望明天天氣會很好。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-167.02": {
      "note": "",
      "translation": "希望以後能賺很多錢。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-168.01": {
      "note": "",
      "translation": "希望明天天氣很好。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-168.02": {
      "note": "",
      "translation": "希望我們全家人都健康。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-169.01": {
      "note": "",
      "source_i18n_id": "ex.ko.s.000567",
      "translation": "這週末要不要一起看電影呢？"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-169.02": {
      "note": "",
      "source_i18n_id": "ex.ko.s.000568",
      "translation": "我要吃涼涼的冷麵。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-170.01": {
      "note": "",
      "translation": "現在沒有原子筆。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-170.02": {
      "note": "",
      "translation": "現在沒有孩子。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-171.01": {
      "note": "",
      "translation": "有書。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-171.02": {
      "note": "",
      "translation": "有詞典。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-172.01": {
      "note": "",
      "translation": "現在房間裡沒有弟弟/妹妹。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-172.02": {
      "note": "",
      "translation": "教室裡沒有老師。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-173.01": {
      "note": "",
      "translation": "在補習班。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-173.02": {
      "note": "",
      "translation": "在商店。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-174.01": {
      "note": "",
      "translation": "今天好像會下雨。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-174.02": {
      "note": "",
      "translation": "這雙鞋對我來說好像太小了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-175.01": {
      "note": "",
      "translation": "想說下午可能會下雨。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-175.02": {
      "note": "",
      "translation": "我想那件衣服可能有點小。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-176.01": {
      "note": "",
      "translation": "我這輩子沒有喝過酒。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-176.02": {
      "note": "",
      "translation": "我這輩子沒有抽過菸。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-177.01": {
      "note": "",
      "translation": "我曾經去過韓國。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-177.02": {
      "note": "",
      "translation": "我以前看過這部電影。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-178.01": {
      "note": "",
      "translation": "打算明年去韓國留學。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-178.02": {
      "note": "",
      "translation": "打算存錢買房子。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-179.01": {
      "note": "",
      "translation": "明天想說要不要看電影。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-179.02": {
      "note": "",
      "translation": "晚餐想說要不要吃炸雞。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-180.01": {
      "note": "",
      "translation": "我喜歡辣的食物。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-180.02": {
      "note": "",
      "translation": "這是小包包。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-181.01": {
      "note": "",
      "translation": "買了明天要喝的牛奶。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-181.02": {
      "note": "",
      "translation": "在濟州島有很多要參觀的地方。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-182.01": {
      "note": "",
      "translation": "昨天讀過的書真的很有趣。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-182.02": {
      "note": "",
      "translation": "這是由我親自做的蛋糕。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-183.01": {
      "note": "",
      "translation": "給正在學習的朋友打了電話。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-183.02": {
      "note": "",
      "translation": "正在唱歌的人是我弟弟。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-184.01": {
      "note": "",
      "translation": "明天去學校。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-184.02": {
      "note": "",
      "translation": "朋友來我們家了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-185.01": {
      "note": "",
      "translation": "為了學韓語來到了韓國。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-185.02": {
      "note": "",
      "translation": "週末打算去山上爬山。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-186.01": {
      "note": "",
      "translation": "最近不下雨。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-186.02": {
      "note": "",
      "translation": "沒吃早餐。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-187.01": {
      "note": "",
      "translation": "昨天因為太累了，所以沒能做作業。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-187.02": {
      "note": "",
      "translation": "因為開會的關係，沒能吃午餐。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-188.01": {
      "note": "",
      "translation": "我今天不吃肉。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-188.02": {
      "note": "",
      "translation": "不喝咖啡。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-189.01": {
      "note": "",
      "translation": "我沒辦法吃辣的食物。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-189.02": {
      "note": "",
      "translation": "因為頭痛，所以沒能讀書。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-190.01": {
      "note": "",
      "translation": "下班之後要一起吃晚餐嗎？"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-190.02": {
      "note": "",
      "translation": "請過 30 分鐘之後再打電話給我。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-191.01": {
      "note": "",
      "translation": "在這些之中最喜歡的水果是什麼？"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-191.02": {
      "note": "",
      "translation": "在韓國料理之中最喜歡石鍋拌飯。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-192.01": {
      "note": "",
      "source_i18n_id": "ex.ko.s.001954",
      "translation": "我只睡了三個小時。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-192.02": {
      "note": "",
      "source_i18n_id": "ex.ko.s.001958",
      "translation": "因為便當只買到一個，好不容易才分著吃了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-193.01": {
      "note": "",
      "translation": "火車比飛機更便宜。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-193.02": {
      "note": "",
      "translation": "冬天比秋天更冷。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-194.01": {
      "note": "",
      "translation": "從家裡開始打掃。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-194.02": {
      "note": "",
      "translation": "要先吃飯嗎？"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-195.01": {
      "note": "",
      "translation": "因為雨的關係，衣服全都濕了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-195.02": {
      "note": "",
      "translation": "因為作業，沒能睡覺。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-196.01": {
      "note": "",
      "translation": "我想像母語者一樣韓文說得非常好。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-196.02": {
      "note": "",
      "translation": "像歌手一樣唱歌唱得很好。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-198.01": {
      "note": "",
      "translation": "週末要不要去看部電影之類的？"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-198.02": {
      "note": "",
      "translation": "好無聊，一起玩個遊戲什麼的吧。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-200.01": {
      "note": "",
      "source_i18n_id": "ex.ko.s.002194",
      "translation": "按照老師吩咐的做了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-200.02": {
      "note": "",
      "source_i18n_id": "ex.ko.s.002195",
      "translation": "一到達請立刻給我打電話。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-201.01": {
      "note": "",
      "translation": "週末也很忙。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-201.02": {
      "note": "",
      "translation": "姊姊也來了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-202.01": {
      "note": "",
      "translation": "假期期間我打算去旅行。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-202.02": {
      "note": "",
      "translation": "我學習了三個小時。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-203.01": {
      "note": "",
      "translation": "關於新的業務開了會。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-203.02": {
      "note": "",
      "translation": "經常考慮關於未來的事。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-204.01": {
      "note": "",
      "translation": "一天大約喝三杯。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-204.02": {
      "note": "",
      "translation": "一週大約去兩次。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-205.01": {
      "note": "",
      "translation": "在餐廳。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-205.02": {
      "note": "",
      "translation": "去公園。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-206.01": {
      "note": "",
      "translation": "給孩子禮物。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-206.02": {
      "note": "",
      "translation": "寄信給部長。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-207.01": {
      "note": "",
      "translation": "向金老師學習韓文。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-207.02": {
      "note": "",
      "translation": "從奶奶那裡收到了禮物。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-208.01": {
      "note": "",
      "translation": "在補習班努力唸書。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-208.02": {
      "note": "",
      "translation": "在客廳舒服地休息。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-209.01": {
      "note": "",
      "translation": "看雜誌。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-209.02": {
      "note": "",
      "translation": "喝水。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-211.01": {
      "note": "",
      "translation": "往海邊去。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-211.02": {
      "note": "",
      "translation": "請往餐廳來。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-212.01": {
      "note": "",
      "translation": "用原子筆寫。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-212.02": {
      "note": "",
      "translation": "搭飛機去。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-213.01": {
      "note": "",
      "translation": "從早上到晚上一直很忙。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-213.02": {
      "note": "",
      "translation": "從星期一到星期五上班。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-214.01": {
      "note": "",
      "translation": "和老公一起運動。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-214.02": {
      "note": "",
      "translation": "和姊姊一起去了。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-217.01": {
      "note": "",
      "translation": "我打算每週末去學料理。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-217.02": {
      "note": "",
      "translation": "請每天早上喝一杯牛奶。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-218.01": {
      "note": "",
      "translation": "想再多睡10分鐘。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-218.02": {
      "note": "",
      "translation": "英秀只愛你。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-221.01": {
      "note": "",
      "translation": "無論哪裡都可以一起去。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-221.02": {
      "note": "",
      "translation": "無論什麼請儘管問。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-224.01": {
      "note": "",
      "translation": "學生和老師在一起。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-224.02": {
      "note": "",
      "translation": "買了蘋果和梨子。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-238.01": {
      "note": "",
      "translation": "今天晚餐打算吃披薩。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-238.02": {
      "note": "",
      "translation": "我明天打算去圖書館。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-239.01": {
      "note": "",
      "translation": "昨天見了朋友。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-239.02": {
      "note": "",
      "translation": "早上吃了麵包。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-240.01": {
      "note": "",
      "translation": "昨天見了朋友。"
    },
    "sent.ko.phase2.grammar.ko-v2-gram-240.02": {
      "note": "",
      "translation": "早上吃了麵包。"
    }
  },
